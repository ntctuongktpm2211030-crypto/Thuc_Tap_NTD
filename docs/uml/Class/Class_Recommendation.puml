@startuml Class_Recommendation

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Recommendations Module " {

  class "RecommendationController" as RecommendationController {
    - service : RecommendationService
    + constructor()
    + createRecommendation(req: Request, res: Response): Promise<Response>
    + getUserRecommendations(req: Request, res: Response): Promise<Response>
    + updateRecommendation(req: Request, res: Response): Promise<Response>
    + deleteRecommendation(req: Request, res: Response): Promise<Response>
  }

  class "RecommendationService" as RecommendationService {
    - repo : RecommendationRepository
    + constructor()
    + createRecommendation(userId: String, data: CreateRecommendationDto): Promise<UserRecommendation>
    + getUserRecommendations(userId: String): Promise<UserRecommendation[]>
    + updateRecommendation(id: String, userId: String, data: UpdateRecommendationDto): Promise<UserRecommendation>
    + deleteRecommendation(id: String, userId: String): Promise<any>
  }

  class "RecommendationRepository" as RecommendationRepository {
    + createRecommendation(userId: String, data: CreateRecommendationDto): Promise<UserRecommendation>
    + getRecommendationsByUserId(userId: String): Promise<UserRecommendation[]>
    + getRecommendationById(id: String): Promise<UserRecommendation | null>
    + updateRecommendation(id: String, data: UpdateRecommendationDto): Promise<UserRecommendation>
    + deleteRecommendation(id: String): Promise<UserRecommendation>
  }
}

RecommendationController *-- RecommendationService
RecommendationService *-- RecommendationRepository

@enduml
