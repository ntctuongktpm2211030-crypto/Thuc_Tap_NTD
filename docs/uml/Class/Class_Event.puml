@startuml Class_Event

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Phan he Phan hoi tu Nguoi dung (Feedback Module)" {

  class "Chuc Nang Phan Hoi\n(FeedbackController)" as FeedbackController {
    - service : FeedbackService
    + constructor()
    + create(req: Request, res: Response): Promise<Response>
    + list(req: Request, res: Response): Promise<Response>
    + update(req: Request, res: Response): Promise<Response>
    + delete(req: Request, res: Response): Promise<Response>
  }

  class "Dich Vu Phan Hoi\n(FeedbackService)" as FeedbackService {
    - repo : FeedbackRepository
    + constructor()
    + create(userId: String, data: CreateFeedbackDto): Promise<AIFeedback>
    + list(userId: String): Promise<AIFeedback[]>
    + update(id: String, userId: String, data: UpdateFeedbackDto): Promise<AIFeedback>
    + delete(id: String, userId: String): Promise<any>
  }

  class "Luu Tru Phan Hoi\n(FeedbackRepository)" as FeedbackRepository {
    + create(userId: String, data: CreateFeedbackDto): Promise<AIFeedback>
    + getByMessageId(messageId: String): Promise<AIFeedback | null>
    + getById(id: String): Promise<AIFeedback | null>
    + update(id: String, data: UpdateFeedbackDto): Promise<AIFeedback>
    + delete(id: String): Promise<AIFeedback>
    + list(userId: String): Promise<AIFeedback[]>
  }
}

FeedbackController *-- FeedbackService
FeedbackService *-- FeedbackRepository

@enduml
