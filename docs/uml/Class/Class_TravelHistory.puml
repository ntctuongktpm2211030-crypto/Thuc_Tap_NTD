@startuml Class_TravelHistory

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Phan he Lich su di du lich (Travel History Module)" {

  class "Chuc Nang Lich Su Di Du Lich\n(TravelHistoryController)" as TravelHistoryController {
    - service : TravelHistoryService
    + constructor()
    + create(req: Request, res: Response): Promise<Response>
    + list(req: Request, res: Response): Promise<Response>
    + update(req: Request, res: Response): Promise<Response>
    + delete(req: Request, res: Response): Promise<Response>
  }

  class "Dich Vu Lich Su Di Du Lich\n(TravelHistoryService)" as TravelHistoryService {
    - repo : TravelHistoryRepository
    + constructor()
    + create(userId: String, data: CreateTravelHistoryDto): Promise<TravelHistory>
    + list(userId: String): Promise<TravelHistory[]>
    + update(id: String, userId: String, data: UpdateTravelHistoryDto): Promise<TravelHistory>
    + delete(id: String, userId: String): Promise<any>
  }

  class "Luu Tru Lich Su Di Du Lich\n(TravelHistoryRepository)" as TravelHistoryRepository {
    + create(userId: String, data: CreateTravelHistoryDto): Promise<TravelHistory>
    + list(userId: String): Promise<TravelHistory[]>
    + getById(id: String): Promise<TravelHistory | null>
    + update(id: String, data: UpdateTravelHistoryDto): Promise<TravelHistory>
    + delete(id: String): Promise<any>
  }
}

TravelHistoryController *-- TravelHistoryService
TravelHistoryService *-- TravelHistoryRepository

@enduml
