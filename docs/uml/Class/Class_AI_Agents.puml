@startuml Class_AI_Agents

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Dieu hanh cac Tro ly AI (AI Agents Module)" {

  class "Chuc Nang Tro Ly AI\n(AgentController)" as AgentController {
    - executor : AgentExecutorService
    + constructor()
    + chat(req: Request, res: Response): Promise<Response>
    + executePlan(req: Request, res: Response): Promise<Response>
    + getAgentState(req: Request, res: Response): Promise<Response>
  }

  class "Dieu Hanh Tro Ly AI\n(AgentExecutorService)" as AgentExecutorService {
    - strategies : Record<AgentType, AgentStrategy>
    - addressService : AddressService
    - stateService : ConversationStateService
    - rerankerService : TravelRerankerService
    - responsePlanner : ResponsePlanner
    - intentService : TravelIntentService
    - slotService : SlotFillingService
    - suggestionService : SuggestionBuilderService
    - formatterService : ResponseFormatterService
    + constructor()
    + execute(userId: String, input: String, agentType?: AgentType): Promise<AgentResponse>
    + getStateService(): ConversationStateService
  }

  class "Xu Ly Dia Chi\n(AddressService)" as AddressService {
    + parseAddress(address: String): Promise<ParsedAddress>
    + cleanAddress(address: String): String
  }

  interface "Chuc Nang Cua Tro Ly\n(AgentStrategy)" as AgentStrategy {
    + execute(input: String, context: AgentContext): Promise<AgentResponse>
  }

  class "Tro Ly Hanh Trinh AI\n(TravelAgent)" as TravelAgent implements AgentStrategy {
    - itineraryTool : ItineraryTool
    - mapTool : MapTool
    - weatherTool : WeatherTool
    + constructor(itineraryTool: ItineraryTool, mapTool: MapTool, weatherTool: WeatherTool)
    + execute(input: String, context: AgentContext): Promise<AgentResponse>
  }

  class "Tro Ly Am Thuc AI\n(FoodAgent)" as FoodAgent implements AgentStrategy {
    - foodTool : FoodTool
    + constructor(foodTool: FoodTool)
    + execute(input: String, context: AgentContext): Promise<AgentResponse>
  }

  class "Tro Ly Van Hoa AI\n(CultureAgent)" as CultureAgent implements AgentStrategy {
    - cultureTool : CultureTool
    + constructor(cultureTool: CultureTool)
    + execute(input: String, context: AgentContext): Promise<AgentResponse>
  }

  class "Tro Ly Goi Y AI\n(RecommendationAgent)" as RecommendationAgent implements AgentStrategy {
    - recommendationTool : RecommendationTool
    + constructor(recommendationTool: RecommendationTool)
    + execute(input: String, context: AgentContext): Promise<AgentResponse>
  }

  ' ─── AGENT TOOLS ───
  interface "Cong Cu Tro Ly\n(AgentTool)" as AgentTool {
    + name : String
    + description : String
    + execute(args: any): Promise<any>
  }

  class "Nut Tim Ban Do\n(MapTool)" as MapTool implements AgentTool {
    + execute(input: { query: String }): Promise<any>
  }

  class "Nut Xem Thoi Tiet\n(WeatherTool)" as WeatherTool implements AgentTool {
    + execute(input: { location: String, date: String }): Promise<any>
  }

  class "Nut Tim Mon An\n(FoodTool)" as FoodTool implements AgentTool {
    + execute(input: { query: String, category?: String }): Promise<any>
  }

  class "Nut Xem Van Hoa\n(CultureTool)" as CultureTool implements AgentTool {
    + execute(input: { region: String }): Promise<any>
  }

  class "Nut Tim Goi Y\n(RecommendationTool)" as RecommendationTool implements AgentTool {
    + execute(input: { userId: String }): Promise<any>
  }

  class "Nut Xem Lich Trinh\n(ItineraryTool)" as ItineraryTool implements AgentTool {
    + execute(input: { destination: String, days: Int }): Promise<any>
  }
}

AgentController *-- AgentExecutorService
AgentExecutorService *-- AddressService
AgentExecutorService *-- AgentStrategy

TravelAgent *-- ItineraryTool
TravelAgent *-- MapTool
TravelAgent *-- WeatherTool
FoodAgent *-- FoodTool
CultureAgent *-- CultureTool
RecommendationAgent *-- RecommendationTool

@enduml
