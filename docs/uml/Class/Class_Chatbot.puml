@startuml Class_Chatbot

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Xu ly Chat bot va Hoi thoai (Chatbot & Dialogue Layer)" {

  class "Xu Ly Yeu Cau Chatbot\n(ChatbotController)" as ChatbotController {
    - service : ChatbotService
    + constructor()
    + createConversation(req: Request, res: Response): Promise<Response>
    + getConversations(req: Request, res: Response): Promise<Response>
    + getConversationDetails(req: Request, res: Response): Promise<Response>
    + deleteConversation(req: Request, res: Response): Promise<Response>
    + sendMessage(req: Request, res: Response): Promise<Response>
    + regenerateResponse(req: Request, res: Response): Promise<Response>
    + getMemory(req: Request, res: Response): Promise<Response>
    + saveMemory(req: Request, res: Response): Promise<Response>
    + deleteMemory(req: Request, res: Response): Promise<Response>
  }

  class "Dich Vu Xu Ly Chatbot\n(ChatbotService)" as ChatbotService {
    - repo : ChatbotRepository
    - agentExecutor : AgentExecutorService
    + constructor()
    + createConversation(userId: String, title?: String): Promise<ChatConversation>
    + getConversations(userId: String): Promise<ChatConversation[]>
    + getConversationDetails(conversationId: String, userId: String): Promise<ChatConversation>
    + deleteConversation(conversationId: String, userId: String): Promise<any>
    + sendMessage(conversationId: String, userId: String, content: String): Promise<SendMessageResult>
    + regenerateResponse(messageId: String, userId: String): Promise<any>
    + getMemory(userId: String): Promise<AIMemory | null>
    + saveMemory(userId: String, data: SaveMemoryDto): Promise<AIMemory>
    + deleteMemory(userId: String): Promise<any>
  }

  class "Luu Tru Chatbot\n(ChatbotRepository)" as ChatbotRepository {
    + createConversation(userId: String, title?: String): Promise<ChatConversation>
    + getConversationsByUserId(userId: String): Promise<ChatConversation[]>
    + getConversationById(id: String, userId: String): Promise<ChatConversation | null>
    + deleteConversation(id: String): Promise<ChatConversation>
    + createMessage(conversationId: String, role: String): Promise<ChatMessage>
    + createMessageVersion(messageId: String, content: String, version: Int, isActive: Boolean): Promise<ChatMessageVersion>
    + deactivateAllVersions(messageId: String): Promise<any>
    + getMessageById(messageId: String): Promise<ChatMessage | null>
    + getActiveVersion(messageId: String): Promise<ChatMessageVersion | null>
    + getMaxVersion(messageId: String): Promise<Int>
    + getConversationHistoryForAI(conversationId: String): Promise<any[]>
    + getMemoryByUserId(userId: String): Promise<AIMemory | null>
    + upsertMemory(userId: String, data: SaveMemoryDto): Promise<AIMemory>
    + deleteMemory(userId: String): Promise<any>
  }

  class "Bo Nao Chatbot\n(ConversationIntelligence)" as ConversationIntelligence {
    - emotionAnalyzer : EmotionAnalyzer
    - ruleOverride : RuleOverrideEngine
    - contextResolver : ContextResolver
    - intentClassifier : IntentClassifier
    - stateMachine : ConversationStateMachine
    - slotPolicy : SlotPolicy
    - responsePolicy : ResponsePolicy
    + constructor()
    + analyzeQuery(query: String, conversationId: String, currentState: String): Promise<CIMResult>
  }

  class "Doc Cam Xuc Khach Hang\n(EmotionAnalyzer)" as EmotionAnalyzer {
    + analyze(query: String): EmotionAnalysis
  }

  class "Quan Ly Buoc Hoi Thoai\n(ConversationStateMachine)" as ConversationStateMachine {
    + transition(currentState: String, intent: String): String
  }

  class "Luat Dien Thong Tin\n(SlotPolicy)" as SlotPolicy {
    + apply(intent: String, needSlot: Boolean): SlotPolicyResult
  }

  class "Luat Tra Loi\n(ResponsePolicy)" as ResponsePolicy {
    + resolveTone(emotion: EmotionAnalysis): String
  }

  class "Bo Sua Loi Chatbot\n(RuleOverrideEngine)" as RuleOverrideEngine {
    + evaluate(query: String, emotion: EmotionAnalysis, context: ContextMemory): IntentResult
  }

  ' ─── DIALOGUE LAYER SERVICES ───
  class "Luu Trang Thai Chat\n(ConversationStateService)" as ConversationStateService {
    + getState(userId: String): Promise<ConversationState>
    + saveState(userId: String, state: ConversationState): Promise<void>
    + resetState(userId: String): Promise<void>
  }

  class "Doan Y Dinh Nguoi Dung\n(TravelIntentService)" as TravelIntentService {
    + classifyIntent(text: String): Promise<IntentClassification>
  }

  class "Chon Loc Dia Diem Hot\n(TravelRerankerService)" as TravelRerankerService {
    + rerankDestinations(results: Destination[], preferences: TravelPreferences): Promise<Destination[]>
  }

  class "Tao Cau Goi Y\n(SuggestionBuilderService)" as SuggestionBuilderService {
    + buildSuggestions(state: ConversationState): Promise<String[]>
  }

  class "Ghi Nhan Thong Tin Lich Trinh\n(SlotFillingService)" as SlotFillingService {
    + extractSlots(text: String): Promise<SlotExtractionResult>
  }

  class "Len Ke Hoach Cau Tra Loi\n(ResponsePlanner)" as ResponsePlanner {
    + planResponse(intent: String, state: ConversationState): Promise<ResponsePlan>
  }

  class "Trinh Bay Cau Tra Loi\n(ResponseFormatterService)" as ResponseFormatterService {
    + formatResponse(plan: ResponsePlan, style: ResponseStyle): Promise<String>
  }

  class "Ghep Thong Tin Gui AI\n(PromptComposerService)" as PromptComposerService {
    + composePrompt(state: ConversationState, ragContext: String): String
  }
}

ChatbotController *-- ChatbotService
ChatbotService *-- ChatbotRepository
ChatbotService *-- ConversationIntelligence

ConversationIntelligence *-- EmotionAnalyzer
ConversationIntelligence *-- ConversationStateMachine
ConversationIntelligence *-- SlotPolicy
ConversationIntelligence *-- ResponsePolicy
ConversationIntelligence *-- RuleOverrideEngine

@enduml
