@startuml Class_ToolCalls

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Phan he Luu vet goi tool (Tool Calls Module)" {

  class "Chuc Nang Goi Tool\n(ToolCallController)" as ToolCallController {
    - service : ToolCallService
    + constructor()
    + create(req: Request, res: Response): Promise<Response>
    + listAll(req: Request, res: Response): Promise<Response>
    + listByMessageId(req: Request, res: Response): Promise<Response>
    + update(req: Request, res: Response): Promise<Response>
    + delete(req: Request, res: Response): Promise<Response>
  }

  class "Dich Vu Goi Tool\n(ToolCallService)" as ToolCallService {
    - repo : ToolCallRepository
    + constructor()
    + create(userId: String, data: CreateToolCallDto): Promise<ToolCall>
    + listAll(userId: String): Promise<ToolCall[]>
    + listByMessageId(userId: String, messageId: String): Promise<ToolCall[]>
    + update(id: String, userId: String, data: UpdateToolCallDto): Promise<ToolCall>
    + delete(id: String, userId: String): Promise<any>
  }

  class "Luu Tru Goi Tool\n(ToolCallRepository)" as ToolCallRepository {
    + create(data: CreateToolCallDto): Promise<ToolCall>
    + listByMessageId(messageId: String): Promise<ToolCall[]>
    + getById(id: String): Promise<ToolCall | null>
    + update(id: String, data: UpdateToolCallDto): Promise<ToolCall>
    + delete(id: String): Promise<any>
    + listAll(userId: String): Promise<ToolCall[]>
  }
}

ToolCallController *-- ToolCallService
ToolCallService *-- ToolCallRepository

@enduml
