@startuml Class_TongQuan

skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam ranksep 80
skinparam nodesep 50

package "Kiem soat & Dinh tuyen (Routing & Security)" {
  class AuthMiddleware {
    + requireAuth(req, res, next)
    + requireAdmin(req, res, next)
    + optionalAuth(req, res, next)
  }
}

package "Phan he Nguoi dung (User & Auth Module)" {
  class AuthController
  class AuthService
  class AuthRepository
}

package "Phan he Hanh trinh tu do (Itinerary Module)" {
  class ItineraryController
  class ItineraryService
  class ItineraryRepository
}

package "Phan he Chuyen di (Trips Module)" {
  class TripsRouter
}

package "Phan he Mang xa hoi (Posts & Social Module)" {
  class PostsRouter
  class SocialRouter
}

package "Phan he AI Chatbot (AI Chatbot Module)" {
  class ChatbotController
  class ChatbotService
}

package "Phan he RAG & Tri thuc (RAG Module)" {
  class RagController
  class RagOrchestratorService
  class VectorStoreService
}

package "Phan he AI Agents (AI Agents Module)" {
  class AgentController
  class AgentExecutorService
}

package "Phan he Phan hoi (Feedback Module)" {
  class FeedbackController
  class FeedbackService
  class FeedbackRepository
}

package "Phan he Bo nho tam (Cache Module)" {
  class CacheService
  class CacheRepository
}

class "PostgreSQL Database" as DB <<Database>>

AuthController ..> AuthService
AuthService ..> AuthRepository
AuthRepository --> DB

ItineraryController ..> ItineraryService
ItineraryService ..> ItineraryRepository
ItineraryRepository --> DB

TripsRouter --> DB
PostsRouter --> DB
SocialRouter --> DB

ChatbotController ..> ChatbotService
ChatbotService --> DB

RagController ..> RagOrchestratorService
RagOrchestratorService ..> VectorStoreService
VectorStoreService --> DB

AgentController ..> AgentExecutorService

FeedbackController ..> FeedbackService
FeedbackService ..> FeedbackRepository
FeedbackRepository --> DB

CacheService ..> CacheRepository
CacheRepository --> DB

@enduml

