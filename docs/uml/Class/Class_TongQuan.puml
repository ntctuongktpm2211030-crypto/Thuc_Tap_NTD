@startuml Class_TongQuan

skinparam linetype ortho
skinparam ranksep 100
skinparam nodesep 80

package "Giao dien Nguoi dung (Client Layer)" {
  component "Giao dien Web\n(React Web UI)" as Frontend
}

package "Kiem soat & Dinh tuyen (Routing & Security Layer)" {
  component "Dinh tuyen Core\n(Express Router Core)" as ExpressRouter
  component "Kiem tra Dang nhap\n(Auth Middleware)" as AuthMiddleware
}

package "Phan he Nghiep vu (Business Layer)" {
  folder "Quan ly Thanh vien" {
    component "Dich vu gui email\n(Email Service)" as EmailService
    component "Dich vu dia diem da luu\n(Saved Place Service)" as SavedPlaceService
    component "Dich vu mon an yeu thich\n(Favorite Food Service)" as FavoriteFoodService
  }
  
  folder "Mang xa hoi va Tuong tac" {
    component "Chuc nang ket noi ban be\n(Social Router)" as SocialRouter
    component "Chuc nang bai dang va binh luan\n(Posts Router)" as PostsRouter
  }

  folder "Hanh trinh va Chuyen di" {
    component "Dich vu hanh trinh tu do\n(Itinerary Service)" as ItineraryService
    component "Dich vu lich su du lich\n(Travel History Service)" as TravelHistoryService
    component "Chuc nang chuyen di\n(Trips Router)" as TripsRouter
  }

  folder "Tro ly AI va Du lieu Ca Mau" {
    component "Dich vu chat bot\n(Chatbot Service)" as ChatbotService
    component "Dieu hanh cac Tro ly AI\n(Agent Executor Service)" as AgentExecutorService
    component "Dieu Phoi RAG\n(RagOrchestratorService)" as RagOrchestratorService
    component "Dich vu goi y\n(Recommendation Service)" as RecommendationService
  }

  folder "Tien ich he thong" {
    component "Bo nho tam\n(Cache Service)" as CacheService
    component "Nguoi dung danh gia AI\n(Feedback Service)" as FeedbackService
    component "Nhat ky goi AI\n(Tool Call Service)" as ToolCallService
  }
}

database "PostgreSQL Database" as DB

Frontend --> ExpressRouter : HTTP Request
ExpressRouter ..> AuthMiddleware : <<validate>>

ExpressRouter --> SocialRouter
ExpressRouter --> PostsRouter
ExpressRouter --> TripsRouter

SocialRouter ..> SavedPlaceService
SocialRouter ..> FavoriteFoodService

TripsRouter ..> ItineraryService
TripsRouter ..> TravelHistoryService

ChatbotService ..> AgentExecutorService
AgentExecutorService ..> RagOrchestratorService

SavedPlaceService --> DB
FavoriteFoodService --> DB
ItineraryService --> DB
TravelHistoryService --> DB
ChatbotService --> DB
RecommendationService --> DB
CacheService --> DB
FeedbackService --> DB
ToolCallService --> DB

@enduml
