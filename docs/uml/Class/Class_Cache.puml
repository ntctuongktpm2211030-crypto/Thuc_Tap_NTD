@startuml Class_Cache

skinparam linetype ortho
skinparam classAttributeIconSize 0

package "Cache Module " {

  class "CacheController" as CacheController {
    - service : CacheService
    + constructor()
    + getValue(req: Request, res: Response): Promise<Response>
    + setValue(req: Request, res: Response): Promise<Response>
    + deleteValue(req: Request, res: Response): Promise<Response>
    + clearAll(req: Request, res: Response): Promise<Response>
    + getKeys(req: Request, res: Response): Promise<Response>
    + getStats(req: Request, res: Response): Promise<Response>
  }

  class "CacheService" as CacheService {
    - repo : CacheRepository
    + constructor()
    + get<T>(key: String): Promise<T | null>
    + set<T>(key: String, value: T, ttlSeconds?: Int): Promise<void>
    + delete(key: String): Promise<void>
    + clear(): Promise<void>
    + getKeys(pattern?: String): Promise<String[]>
    + getStats(): Promise<CacheStats>
  }

  class "CacheRepository" as CacheRepository {
    + get(key: String): Promise<String | null>
    + set(key: String, value: String, ttlSeconds?: Int): Promise<void>
    + delete(key: String): Promise<void>
    + clear(): Promise<void>
    + scanKeys(pattern: String): Promise<String[]>
    + countKeys(): Promise<Int>
  }
}

CacheController *-- CacheService
CacheService *-- CacheRepository

@enduml
