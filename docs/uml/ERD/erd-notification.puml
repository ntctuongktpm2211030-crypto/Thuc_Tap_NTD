@startuml
!startsub NOTIFICATION
entity Notification {
  * id : String <<PK>>
  --
  * recipientId : String <<FK>> <<index>>
  * type : String
  * content : String
  * isRead : Boolean
  * createdAt : DateTime
}

User ||--o{ Notification : "receives notifications"
!endsub

