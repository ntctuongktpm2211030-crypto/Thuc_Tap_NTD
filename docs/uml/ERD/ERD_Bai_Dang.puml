@startuml ERD_Bai_Dang

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Bài viết & Tương tác" {
  entity "Bài đăng" as BaiDang {
    * ma_bai_dang : String <<PK>>
    --
    * ma_tac_gia : String <<FK>> <<INDEX>>
    * noi_dung : String
    * danh_sach_anh : String[]
    ma_chuyen_di : String <<FK>> <<INDEX>>
    ma_dia_diem : String
    * ngay_tao : DateTime
    ngay_xoa : DateTime
  }

  entity "Bình luận" as BinhLuan {
    * ma_binh_luan : String <<PK>>
    --
    * ma_bai_dang : String <<FK>> <<INDEX>>
    * ma_tac_gia : String <<FK>> <<INDEX>>
    * noi_dung : String
    ma_binh_luan_cha : String <<FK>> <<INDEX>>
    * ngay_tao : DateTime
  }

  entity "Lượt thích" as LuotThich {
    * ma_luot_thich : String <<PK>>
    --
    * ma_bai_dang : String <<FK>> <<UNIQUE>>
    * ma_nguoi_dung : String <<FK>> <<UNIQUE>>
    * ngay_tao : DateTime
  }

  entity "Đánh dấu" as DanhDau {
    * ma_danh_dau : String <<PK>>
    --
    * ma_bai_dang : String <<FK>> <<UNIQUE>>
    * ma_nguoi_dung : String <<FK>> <<UNIQUE>>
    * ngay_tao : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as NguoiDung <<External>>
entity "Chuyến đi" as ChuyenDi <<External>>

NguoiDung ||--o{ BaiDang : "đăng"
NguoiDung ||--o{ BinhLuan : "viết"
NguoiDung ||--o{ LuotThich : "thích"
NguoiDung ||--o{ DanhDau : "lưu"

ChuyenDi ||--o{ BaiDang : "chia sẻ"

BaiDang ||--o{ BinhLuan : "có"
BaiDang ||--o{ LuotThich : "nhận"
BaiDang ||--o{ DanhDau : "nhận lưu"

BinhLuan ||--o{ BinhLuan : "phản hồi"

@enduml
