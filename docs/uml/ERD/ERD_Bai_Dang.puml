@startuml ERD_Bai_Dang

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Bài viết & Tương tác" {
  entity "Post" as Post {
    * id : String <<PK>>
    --
    * authorId : String <<FK>> <<INDEX>>
    * content : String
    * mediaUrls : String[]
    tripId : String <<FK>> <<INDEX>>
    locationId : String
    * createdAt : DateTime
    deletedAt : DateTime
  }

  entity "Comment" as Comment {
    * id : String <<PK>>
    --
    * postId : String <<FK>> <<INDEX>>
    * authorId : String <<FK>> <<INDEX>>
    * content : String
    parentId : String <<FK>> <<INDEX>>
    * createdAt : DateTime
  }

  entity "Like" as Like {
    * id : String <<PK>>
    --
    * postId : String <<FK>>
    * userId : String <<FK>>
    * createdAt : DateTime
    --
    UNIQUE(postId, userId)
  }

  entity "Bookmark" as Bookmark {
    * id : String <<PK>>
    --
    * postId : String <<FK>>
    * userId : String <<FK>>
    * createdAt : DateTime
    --
    UNIQUE(postId, userId)
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "User" as User <<External>>
entity "Trip" as Trip <<External>>

User ||--o{ Post : "author"
User ||--o{ Comment : "author"
User ||--o{ Like : "user"
User ||--o{ Bookmark : "user"

Trip ||--o{ Post : "trip"

Post ||--o{ Comment : "comments"
Post ||--o{ Like : "likes"
Post ||--o{ Bookmark : "bookmarks"

Comment ||--o{ Comment : "replies"

@enduml
