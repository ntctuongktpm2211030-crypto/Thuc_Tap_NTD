@startuml ERD_Bai_Dang

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Bài viết & Tương tác" {
  entity "Bai dang" as Post {
    * PK | id : String
    --
    * FK1 | authorId : String <<INDEX>>
    | FK2 | tripId : String <<INDEX>>
    | FK3 | locationId : String <<INDEX>>
    * | content : String
    * | mediaUrls : String[]
    * | createdAt : DateTime
    | deletedAt : DateTime
  }

  entity "Binh luan" as Comment {
    * PK | id : String
    --
    * FK1 | postId : String <<INDEX>>
    * FK2 | authorId : String <<INDEX>>
    | FK3 | parentId : String <<INDEX>>
    * | content : String
    * | createdAt : DateTime
  }

  entity "Thich" as Like {
    * PK | id : String
    --
    * FK1 | postId : String
    * FK2 | userId : String
    * | createdAt : DateTime
    --
    UNIQUE(postId, userId)
  }

  entity "Luu tru" as Bookmark {
    * PK | id : String
    --
    * FK1 | postId : String
    * FK2 | userId : String
    * | createdAt : DateTime
    --
    UNIQUE(postId, userId)
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as User <<External>>
entity "Chuyến đi" as Trip <<External>>
entity "Điểm đến" as Destination <<External>>

User ||--o{ Post : "tác giả"
User ||--o{ Comment : "tác giả"
User ||--o{ Like : "người dùng"
User ||--o{ Bookmark : "người dùng"

Trip ||--o{ Post : "chuyến đi"
Destination ||--o{ Post : "địa điểm"

Post ||--o{ Comment : "bình luận"
Post ||--o{ Like : "lượt thích"
Post ||--o{ Bookmark : "lượt lưu"

Comment ||--o{ Comment : "phản hồi"

@enduml
