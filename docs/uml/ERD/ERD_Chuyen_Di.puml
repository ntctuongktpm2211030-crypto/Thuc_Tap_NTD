@startuml ERD_Chuyen_Di

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Quản lý chuyến đi" {
  entity "Trip" as Trip {
    * id : String <<PK>>
    --
    * ownerId : String <<FK>> <<INDEX>>
    * title : String
    description : String
    * destinationName : String
    startDate : DateTime
    endDate : DateTime
    * totalBudget : Float
    * travelStyle : String
    * isPublic : Boolean
    * status : TripStatus
    cloneSourceId : String <<FK>> <<INDEX>>
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "TripDay" as TripDay {
    * id : String <<PK>>
    --
    * tripId : String <<FK>>
    * dayIndex : Int
    date : DateTime
  }

  entity "TripActivity" as TripActivity {
    * id : String <<PK>>
    --
    * tripDayId : String <<FK>> <<INDEX>>
    destinationId : String <<FK>> <<INDEX>>
    title : String
    location : String
    description : String
    startTime : String
    endTime : String
    * estimatedCost : Float
    * sequenceOrder : Int
    notes : String
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "User" as User <<External>>
entity "Destination" as Destination <<External>>
entity "Post" as Post <<External>>
entity "Recommendation" as Recommendation <<External>>

User ||--o{ Trip : "owner"
Trip ||--o{ TripDay : "days"
TripDay ||--o{ TripActivity : "activities"
Destination ||--o{ TripActivity : "destination"

Trip ||--o{ Recommendation : "recommendations"
Trip ||--o{ Post : "posts"

@enduml
