@startuml ERD_Chuyen_Di

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Quản lý chuyến đi" {
  entity "Chuyen di" as Trip {
    * PK | id : String
    --
    * FK1 | ownerId : String <<INDEX>>
    | FK2 | cloneSourceId : String <<INDEX>>
    * | title : String
    | description : String
    * | destinationName : String
    | startDate : DateTime
    | endDate : DateTime
    * | totalBudget : Float
    * | travelStyle : String
    * | isPublic : Boolean
    * | status : TripStatus
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Ngay chuyen di" as TripDay {
    * PK | id : String
    --
    * FK1 | tripId : String
    * | dayIndex : Int
    | date : DateTime
  }

  entity "Hoat dong chuyen di" as TripActivity {
    * PK | id : String
    --
    * FK1 | tripDayId : String <<INDEX>>
    | FK2 | destinationId : String <<INDEX>>
    | title : String
    | location : String
    | description : String
    | startTime : String
    | endTime : String
    * | estimatedCost : Float
    * | sequenceOrder : Int
    | notes : String
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as User <<External>>
entity "Điểm đến" as Destination <<External>>
entity "Bài đăng" as Post <<External>>
entity "Đề xuất" as Recommendation <<External>>

User ||--o{ Trip : "chủ sở hữu"
Trip ||--o{ TripDay : "ngày đi"
TripDay ||--o{ TripActivity : "hoạt động"
Destination ||--o{ TripActivity : "điểm đến"

Trip ||--o{ Recommendation : "đề xuất"
Trip ||--o{ Post : "bài đăng"

@enduml
