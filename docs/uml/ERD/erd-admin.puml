@startuml
!startsub ADMIN
entity SafetyWarning {
  * id : String <<PK>>
  --
  * type : String
  * description : String
  * latitude : Float <<index: lat, lng>>
  * longitude : Float <<index: lat, lng>>
  * radiusKm : Float
  * createdAt : DateTime
  expiresAt : DateTime <<nullable>>
}

entity PlaceCache {
  * key : String <<PK>>
  --
  * value : String
  * expiresAt : DateTime
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity FoodCache {
  * key : String <<PK>>
  --
  * value : String
  * expiresAt : DateTime
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity BlogCache {
  * key : String <<PK>>
  --
  * value : String
  * expiresAt : DateTime
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity KnowledgeContent {
  * id : String <<PK>>
  --
  * title : String
  * body : String
  * category : String <<index>>
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity KnowledgeQuestion {
  * id : String <<PK>>
  --
  * contentId : String <<FK>> <<index>>
  * questionText : String
  embeddingOpenAI : Unsupported <<nullable>>
  embeddingLocal : Unsupported <<nullable>>
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity KnowledgeAnswer {
  * id : String <<PK>>
  --
  * contentId : String <<FK>> <<index>>
  * answerText : String
  * createdAt : DateTime
  * updatedAt : DateTime
}

KnowledgeContent ||--o{ KnowledgeQuestion : "links sample questions"
KnowledgeContent ||--o{ KnowledgeAnswer : "links answers templates"
!endsub

!startsub ADMIN_OVERVIEW
entity SafetyWarning {
  * id : String <<PK>>
  --
  * type : String
  * latitude : Float
  * longitude : Float
  * radiusKm : Float
}

entity KnowledgeContent {
  * id : String <<PK>>
  --
  * title : String
  * category : String
}

entity KnowledgeQuestion {
  * id : String <<PK>>
  --
  * contentId : String <<FK>>
  * questionText : String
}

KnowledgeContent ||--o{ KnowledgeQuestion : "links sample questions"
!endsub
@enduml
