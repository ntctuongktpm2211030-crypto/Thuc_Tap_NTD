@startuml ERD_Chatbot_AI

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Trợ lý Chatbot AI" {
  entity "Cuoc hoi thoai AI" as CuocHoiThoaiAI {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    | title : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Tin nhan AI" as TinNhanAI {
    * PK | id : String
    --
    * FK1 | conversationId : String <<INDEX>>
    * | role : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Phien ban tin nhan AI" as PhienBanTinNhanAI {
    * PK | id : String
    --
    * FK1 | messageId : String <<INDEX>>
    * | content : String
    * | version : Int
    * | isActive : Boolean
    * | createdAt : DateTime
  }

  entity "Goi cong cu AI" as GoiCongCuAI {
    * PK | id : String
    --
    * FK1 | messageId : String <<INDEX>>
    * | toolName : String
    * | input : String
    | output : String
    * | status : String
    * | createdAt : DateTime
  }

  entity "Danh gia tin nhan AI" as DanhGiaTinNhanAI {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * FK2 | messageId : String <<UNIQUE>> <<INDEX>>
    * | rating : Int
    | comment : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Bo nho AI" as BoNhoAI {
    * PK | id : String
    --
    * FK1 | userId : String <<UNIQUE>>
    | travelPreferences : String[]
    | favoriteFoods : String[]
    | budget : String
    | transportation : String[]
    | favoriteLocations : String[]
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Mon an yeu thich" as MonAnYeuThich {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | name : String
    | region : String
    | description : String
    | rating : Float
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as NguoiDung <<External>>

NguoiDung ||--o{ CuocHoiThoaiAI : "trò chuyện"
CuocHoiThoaiAI ||--o{ TinNhanAI : "gồm"
TinNhanAI ||--o{ PhienBanTinNhanAI : "có phiên bản"
TinNhanAI ||--o{ GoiCongCuAI : "gọi"
TinNhanAI ||--|| DanhGiaTinNhanAI : "được đánh giá"
NguoiDung ||--o{ DanhGiaTinNhanAI : "đánh giá"

NguoiDung ||--|| BoNhoAI : "sở hữu"
NguoiDung ||--o{ MonAnYeuThich : "yêu thích"

@enduml
