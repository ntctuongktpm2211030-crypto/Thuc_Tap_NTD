@startuml ERD_Tong_Quan

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Người dùng và Cá nhân hóa" {
  entity "User" as User
  entity "Profile" as Profile
  entity "TravelPreferences" as TravelPreferences
  entity "AIMemory" as AIMemory
}

package "Hành trình và Chuyến đi" {
  entity "Trip" as Trip
  entity "Journey" as Journey
}

package "Địa điểm và GIS" {
  entity "Destination" as Destination
  entity "SafetyWarning" as SafetyWarning
}

package "Mạng xã hội và Tương tác" {
  entity "Post" as Post
}

package "Sự kiện và Kết nối" {
  entity "Event" as Event
  entity "TravelerMatch" as TravelerMatch
}

package "Trợ lý Chatbot AI" {
  entity "ChatConversation" as ChatConversation
}

package "Hệ thống RAG và Tri thức" {
  entity "KnowledgeContent" as KnowledgeContent
}

package "Đệm Cache và Nhật ký" {
  entity "FavoriteFood" as FavoriteFood
  entity "SystemCache" as SystemCache
}

' ─── QUAN HỆ TỔNG QUAN GIỮA CÁC MODULES ───

User ||--|| Profile : "profile"
User ||--|| TravelPreferences : "preferences"
User ||--|| AIMemory : "aiMemory"

User ||--o{ Trip : "trips"
User ||--o{ Post : "posts"
User ||--o{ Journey : "journeys"
User ||--o{ Event : "organizedEvents"
User ||--o{ ChatConversation : "chatbotConversations"
User ||--o{ FavoriteFood : "favoriteFoods"
User ||--o{ TravelerMatch : "matches"

Trip }o--|| Destination : "destination"
Trip ||--o{ Post : "posts"

Event }o--|| Destination : "destination"
User }o--o{ Event : "eventAttendances"

@enduml
