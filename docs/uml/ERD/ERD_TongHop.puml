package "Authentication & User" #E3F2FD {
  entity User {
    * id : String <<PK>>
    --
    * email : String <<UNIQUE>>
    * passwordHash : String
    role : UserRole
    isVerified : Boolean
    createdAt : DateTime
    updatedAt : DateTime
  }

  entity Profile {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    fullName : String
    avatarUrl : String
    coverUrl : String
    bio : String
    phoneNumber : String
    homeLocation : String
  }

  entity TravelPreferences {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    * preferredPace : String
    * dailyBudget : Float
    activities : String[]
    destinationTypes : String[]
    foodPreferences : String[]
  }

  entity Follower {
    * id : String <<PK>>
    --
    * followerId : String <<FK>>
    * followingId : String <<FK>>
    createdAt : DateTime
  }

  entity Location {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    * latitude : Float
    * longitude : Float
    updatedAt : DateTime
  }

  entity LocationHistory {
    * id : String <<PK>>
    --
    * userId : String <<FK>>
    * latitude : Float
    * longitude : Float
    accuracy : Float
    speed : Float
    heading : Float
    createdAt : DateTime
  }

  entity Notification {
    * id : String <<PK>>
    --
    * recipientId : String <<FK>>
    * type : String
    * content : String
    isRead : Boolean
    targetId : String
    createdAt : DateTime
  }

  entity TravelerMatch {
    * id : String <<PK>>
    --
    * userId : String <<FK>>
    * matchedUserId : String <<FK>>
    * compatScore : Float
    matchReasons : String[]
    status : String
    createdAt : DateTime
    updatedAt : DateTime
  }
}

