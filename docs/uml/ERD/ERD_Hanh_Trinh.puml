@startuml ERD_Hanh_Trinh

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Nhật trình di chuyển" {
  entity "Hanh trinh" as Journey {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | title : String
    | description : String
    | coverImageUrl : String
    * | isPublic : Boolean
    * | status : String <<INDEX>>
    | startDate : DateTime
    | endDate : DateTime
    * | totalDistance : Float
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Tuyen duong" as Route {
    * PK | id : String
    --
    * FK1 | journeyId : String <<INDEX>>
    * | name : String
    | description : String
    * | transportMode : String
    * | distanceKm : Float
    * | durationMin : Int
    * | color : String
    * | createdAt : DateTime
  }

  entity "Diem tuyen duong" as RoutePoint {
    * PK | id : String
    --
    * FK1 | routeId : String <<INDEX>>
    * | latitude : Float <<INDEX>>
    * | longitude : Float <<INDEX>>
    | altitude : Float
    * | sequenceOrder : Int
    * | timestamp : DateTime
    | note : String
    | photoUrl : String
  }

  entity "Lich su vi tri" as LocationHistory {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | latitude : Float <<INDEX>>
    * | longitude : Float <<INDEX>>
    | accuracy : Float
    | speed : Float
    | heading : Float
    * | createdAt : DateTime <<INDEX>>
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as User <<External>>

User ||--o{ Journey : "người dùng"
User ||--o{ LocationHistory : "lịch sử vị trí"

Journey ||--o{ Route : "tuyến đường"
Route ||--o{ RoutePoint : "điểm tọa độ"

@enduml
