@startuml ERD_Hanh_Trinh

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Nhật trình di chuyển" {
  entity "Journey" as Journey {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * title : String
    description : String
    coverImageUrl : String
    * isPublic : Boolean
    * status : String <<INDEX>>
    startDate : DateTime
    endDate : DateTime
    * totalDistance : Float
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "Route" as Route {
    * id : String <<PK>>
    --
    * journeyId : String <<FK>> <<INDEX>>
    * name : String
    description : String
    * transportMode : String
    * distanceKm : Float
    * durationMin : Int
    * color : String
    * createdAt : DateTime
  }

  entity "RoutePoint" as RoutePoint {
    * id : String <<PK>>
    --
    * routeId : String <<FK>> <<INDEX>>
    * latitude : Float <<INDEX>>
    * longitude : Float <<INDEX>>
    altitude : Float
    * sequenceOrder : Int
    * timestamp : DateTime
    note : String
    photoUrl : String
  }

  entity "LocationHistory" as LocationHistory {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * latitude : Float <<INDEX>>
    * longitude : Float <<INDEX>>
    accuracy : Float
    speed : Float
    heading : Float
    * createdAt : DateTime <<INDEX>>
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "User" as User <<External>>

User ||--o{ Journey : "user"
User ||--o{ LocationHistory : "locationHistory"

Journey ||--o{ Route : "routes"
Route ||--o{ RoutePoint : "points"

@enduml
