@startuml
!startsub USER
entity Follower {
  * id : String <<PK>>
  --
  * followerId : String <<FK>> <<unique: followerId, followingId>>
  * followingId : String <<FK>> <<unique: followerId, followingId>>
  * createdAt : DateTime
}

entity AIMemory {
  * id : String <<PK>>
  --
  * userId : String <<FK>> <<unique>>
  * travelPreferences : String[]
  * favoriteFoods : String[]
  budget : String <<nullable>>
  * transportation : String[]
  * favoriteLocations : String[]
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity Location {
  * id : String <<PK>>
  --
  * userId : String <<FK>> <<unique>>
  * latitude : Float
  * longitude : Float
  * updatedAt : DateTime
}

entity TravelerMatch {
  * id : String <<PK>>
  --
  * userId : String <<FK>> <<unique: userId, matchedUserId>> <<index>>
  * matchedUserId : String <<FK>> <<unique: userId, matchedUserId>> <<index>>
  * compatScore : Float <<index>>
  * matchReasons : String[]
  * status : String
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity Conversation {
  * id : String <<PK>>
  --
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity Message {
  * id : String <<PK>>
  --
  * conversationId : String <<FK>> <<index>>
  * senderId : String <<FK>>
  * content : String
  * createdAt : DateTime
}

entity ChatConversation {
  * id : String <<PK>>
  --
  * userId : String <<FK>> <<index>>
  title : String <<nullable>>
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity ChatMessage {
  * id : String <<PK>>
  --
  * conversationId : String <<FK>> <<index>>
  * role : String
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity ChatMessageVersion {
  * id : String <<PK>>
  --
  * messageId : String <<FK>> <<index>>
  * content : String
  * version : Int
  * isActive : Boolean
  * createdAt : DateTime
}

User ||--o{ Follower : "follower relationship (follower)"
User ||--o{ Follower : "follower relationship (following)"
User ||--o| AIMemory : "has chatbot memory"
User ||--o| Location : "has active location"
User ||--o{ TravelerMatch : "matches profiles"
User ||--o{ TravelerMatch : "targets matching"
User ||--o{ Message : "sends messages"
Conversation ||--o{ Message : "holds chat history"
User }o--o{ Conversation : "participants list"
User ||--o{ ChatConversation : "has chatbot sessions"
ChatConversation ||--o{ ChatMessage : "holds messages"
ChatMessage ||--o{ ChatMessageVersion : "has edit versions"
!endsub

!startsub USER_OVERVIEW
entity Conversation {
  * id : String <<PK>>
  --
  * createdAt : DateTime
}

entity Message {
  * id : String <<PK>>
  --
  * conversationId : String <<FK>>
  * senderId : String <<FK>>
  * content : String
}

entity ChatConversation {
  * id : String <<PK>>
  --
  * userId : String <<FK>>
  title : String <<nullable>>
}

entity ChatMessage {
  * id : String <<PK>>
  --
  * conversationId : String <<FK>>
  * role : String
}

User ||--o{ ChatConversation : "has chatbot sessions"
ChatConversation ||--o{ ChatMessage : "holds messages"
Conversation ||--o{ Message : "holds chat history"
User }o--o{ Conversation : "participants list"
!endsub
@enduml
