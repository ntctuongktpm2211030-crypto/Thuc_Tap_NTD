@startuml ERD_Su_Kien

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Sự kiện & Giao lưu" {
  entity "Su kien" as Event {
    * PK | id : String
    --
    | FK1 | destinationId : String
    * FK2 | organizerId : String <<INDEX>>
    * | title : String
    | description : String
    | coverImageUrl : String
    * | latitude : Float <<INDEX>>
    * | longitude : Float <<INDEX>>
    * | startDate : DateTime <<INDEX>>
    | endDate : DateTime
    * | category : String <<INDEX>>
    | maxAttendees : Int
    * | currentCount : Int
    * | isPublic : Boolean
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Nguoi tham gia su kien" as EventAttendee {
    * PK | id : String
    --
    * FK1 | eventId : String
    * FK2 | userId : String
    * | status : String
    * | createdAt : DateTime
    --
    UNIQUE(eventId, userId)
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as User <<External>>
entity "Điểm đến" as Destination <<External>>

User ||--o{ Event : "sự kiện tổ chức"
User ||--o{ EventAttendee : "người tham gia"
Destination ||--o{ Event : "sự kiện"

Event ||--o{ EventAttendee : "người tham gia"

@enduml
