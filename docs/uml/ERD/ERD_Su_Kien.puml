@startuml ERD_Su_Kien

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Sự kiện & Giao lưu" {
  entity "Sự kiện" as SuKien {
    * ma_su_kien : String <<PK>>
    --
    * tieu_de : String
    mo_ta : String
    anh_bia : String
    ma_diem_den : String <<FK>>
    * vi_do : Float <<INDEX>>
    * kinh_do : Float <<INDEX>>
    * ngay_bat_dau : DateTime <<INDEX>>
    ngay_ket_thuc : DateTime
    * the_loai : String <<INDEX>>
    so_nguoi_toi_da : Int
    * so_nguoi_hien_tai : Int
    * ma_nguoi_to_chuc : String <<FK>> <<INDEX>>
    * cong_khai : Boolean
    * ngay_tao : DateTime
    * ngay_cap_nhat : DateTime
  }

  entity "Người tham gia sự kiện" as NguoiThamGiaSuKien {
    * ma_tham_gia : String <<PK>>
    --
    * ma_su_kien : String <<FK>> <<UNIQUE>>
    * ma_nguoi_dung : String <<FK>> <<UNIQUE>>
    * trang_thai : String
    * ngay_tao : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as NguoiDung <<External>>
entity "Điểm đến" as DiemDen <<External>>

NguoiDung ||--o{ SuKien : "tổ chức"
NguoiDung ||--o{ NguoiThamGiaSuKien : "tham gia"
DiemDen ||--o{ SuKien : "nơi tổ chức"

SuKien ||--o{ NguoiThamGiaSuKien : "thu hút"

@enduml
