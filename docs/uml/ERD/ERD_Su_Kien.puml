@startuml ERD_Su_Kien

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Sự kiện & Giao lưu" {
  entity "Event" as Event {
    * id : String <<PK>>
    --
    * title : String
    description : String
    coverImageUrl : String
    destinationId : String <<FK>>
    * latitude : Float <<INDEX>>
    * longitude : Float <<INDEX>>
    * startDate : DateTime <<INDEX>>
    endDate : DateTime
    * category : String <<INDEX>>
    maxAttendees : Int
    * currentCount : Int
    * organizerId : String <<FK>> <<INDEX>>
    * isPublic : Boolean
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "EventAttendee" as EventAttendee {
    * id : String <<PK>>
    --
    * eventId : String <<FK>> <<UNIQUE>>
    * userId : String <<FK>> <<UNIQUE>>
    * status : String
    * createdAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "User" as User <<External>>
entity "Destination" as Destination <<External>>

User ||--o{ Event : "organizedEvents"
User ||--o{ EventAttendee : "attendees"
Destination ||--o{ Event : "events"

Event ||--o{ EventAttendee : "attendees"

@enduml
