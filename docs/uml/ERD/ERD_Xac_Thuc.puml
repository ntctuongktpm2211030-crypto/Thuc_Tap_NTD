@startuml ERD_Xac_Thuc

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Xác thực & Cá nhân hóa" {
  entity "User" as User {
    * id : String <<PK>>
    --
    * email : String <<UNIQUE>> <<INDEX>>
    * passwordHash : String
    * role : UserRole
    * isVerified : Boolean
    verificationToken : String
    resetPasswordToken : String
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "Profile" as Profile {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    * fullName : String
    avatarUrl : String
    coverUrl : String
    bio : String
    phoneNumber : String
    homeLocation : String
  }

  entity "TravelPreferences" as TravelPreferences {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    * preferredPace : String
    * dailyBudget : Float
    * activities : String[]
    * destinationTypes : String[]
    * foodPreferences : String[]
  }

  entity "AIMemory" as AIMemory {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    travelPreferences : String[]
    favoriteFoods : String[]
    budget : String
    transportation : String[]
    favoriteLocations : String[]
    * createdAt : DateTime
    * updatedAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Trip" as Trip <<External>>
entity "Post" as Post <<External>>
entity "ChatConversation" as ChatConversation <<External>>

User ||--|| Profile : "profile"
User ||--|| TravelPreferences : "preferences"
User ||--|| AIMemory : "aiMemory"

User ||--o{ Trip : "trips"
User ||--o{ Post : "posts"
User ||--o{ ChatConversation : "chatbotConversations"

@enduml
