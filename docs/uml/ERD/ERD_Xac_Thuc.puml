@startuml ERD_Xac_Thuc

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Xác thực & Cá nhân hóa" {
  entity "Nguoi dung" as User {
    * PK | id : String
    --
    * | email : String <<UNIQUE>> <<INDEX>>
    * | passwordHash : String
    * | role : UserRole
    * | isVerified : Boolean
    | verificationToken : String
    | resetPasswordToken : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Ho so" as Profile {
    * PK | id : String
    --
    * FK1 | userId : String <<UNIQUE>>
    * | fullName : String
    | avatarUrl : String
    | coverUrl : String
    | bio : String
    | phoneNumber : String
    | homeLocation : String
  }

  entity "So thich du lich" as TravelPreferences {
    * PK | id : String
    --
    * FK1 | userId : String <<UNIQUE>>
    * | preferredPace : String
    * | dailyBudget : Float
    * | activities : String[]
    * | destinationTypes : String[]
    * | foodPreferences : String[]
  }

  entity "Bo nho AI" as AIMemory {
    * PK | id : String
    --
    * FK1 | userId : String <<UNIQUE>>
    | travelPreferences : String[]
    | favoriteFoods : String[]
    | budget : String
    | transportation : String[]
    | favoriteLocations : String[]
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Chuyến đi" as Trip <<External>>
entity "Bài đăng" as Post <<External>>
entity "Cuộc hội thoại AI" as ChatConversation <<External>>

User ||--|| Profile : "hồ sơ"
User ||--|| TravelPreferences : "sở thích"
User ||--|| AIMemory : "bộ nhớ AI"

User ||--o{ Trip : "chuyến đi"
User ||--o{ Post : "bài đăng"
User ||--o{ ChatConversation : "hội thoại AI"

@enduml
