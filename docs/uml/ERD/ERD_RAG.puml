@startuml ERD_RAG

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Hệ thống RAG và Tri thức" {
  entity "KnowledgeContent" as KnowledgeContent {
    * id : String <<PK>>
    --
    * title : String
    * body : String
    * category : String <<INDEX>>
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "KnowledgeQuestion" as KnowledgeQuestion {
    * id : String <<PK>>
    --
    * contentId : String <<FK>> <<INDEX>>
    * questionText : String
    embeddingOpenAI : Unsupported
    embeddingLocal : Unsupported
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "KnowledgeAnswer" as KnowledgeAnswer {
    * id : String <<PK>>
    --
    * contentId : String <<FK>> <<INDEX>>
    * answerText : String
    * createdAt : DateTime
    * updatedAt : DateTime
  }
}

KnowledgeContent ||--o{ KnowledgeQuestion : "questions"
KnowledgeContent ||--o{ KnowledgeAnswer : "answers"

@enduml
