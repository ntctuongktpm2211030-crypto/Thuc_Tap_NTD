@startuml
!startsub MEDIA
entity Journey {
  * id : String <<PK>>
  --
  * userId : String <<FK>> <<index>>
  * title : String
  description : String <<nullable>>
  coverImageUrl : String <<nullable>>
  * isPublic : Boolean
  * status : String <<index>>
  startDate : DateTime <<nullable>>
  endDate : DateTime <<nullable>>
  * totalDistance : Float
  * createdAt : DateTime
  * updatedAt : DateTime
}

entity Route {
  * id : String <<PK>>
  --
  * journeyId : String <<FK>> <<index>>
  * name : String
  description : String <<nullable>>
  * transportMode : String
  * distanceKm : Float
  * durationMin : Int
  * color : String
  * createdAt : DateTime
}

entity RoutePoint {
  * id : String <<PK>>
  --
  * routeId : String <<FK>> <<index>>
  * latitude : Float <<index: lat, lng>>
  * longitude : Float <<index: lat, lng>>
  altitude : Float <<nullable>>
  * sequenceOrder : Int
  * timestamp : DateTime
  note : String <<nullable>>
  photoUrl : String <<nullable>>
}

Journey ||--o{ Route : "plans paths"
Route ||--o{ RoutePoint : "contains GPS waypoints"
User ||--o{ Journey : "creates stories"
!endsub

!startsub MEDIA_OVERVIEW
entity Journey {
  * id : String <<PK>>
  --
  * userId : String <<FK>>
  * title : String
  * status : String
  * totalDistance : Float
}

User ||--o{ Journey : "creates stories"
!endsub
@enduml
