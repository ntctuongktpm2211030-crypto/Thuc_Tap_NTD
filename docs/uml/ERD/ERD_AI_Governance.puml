@startuml ERD_AI_Governance

left to right direction
skinparam linetype ortho
skinparam ranksep 100
skinparam nodesep 80
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Quản trị & Kiểm toán AI" {
  entity "Dang ky mo hinh" as ModelRegistry {
    * PK | id : String
    --
    * | name : String <<UNIQUE>>
    * | provider : String
    * | type : String
    * | version : String
    * | isActive : Boolean
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Phien ban prompt" as PromptVersion {
    * PK | id : String
    --
    * | templateName : String
    * | versionHash : String <<UNIQUE>>
    * | templateText : String
    * | isActive : Boolean
    * | createdAt : DateTime
  }

  entity "Nhat ky chat AI" as AIChatLog {
    * PK | id : String
    --
    * FK1 | messageId : String <<UNIQUE>>
    * FK2 | modelId : String
    * FK3 | promptId : String
    * | query : String
    * | llmPrompt : String
    * | llmResponse : String
    * | similarityScore : Float
    * | confidenceScore : Int
    * | reliabilityLevel : String
    * | groundednessScore : Int
    * | claimVerScore : Int
    * | retrievedContext : String
    * | promptTokens : Int
    * | completionTokens : Int
    * | totalTokens : Int
    * | apiCostUsd : Float
    * | latencyMs : Int
    * | ttftMs : Int
    * | guardrailsBlocked : Boolean
    | securityThreatType : String
    | unsupportedClaims : Int
    * | createdAt : DateTime
  }

  entity "Phan hoi nguoi dung" as UserFeedback {
    * PK | id : String
    --
    * FK1 | chatLogId : String
    * | rating : Int
    | comment : String
    | correctedText : String
    * | isProcessed : Boolean
    * | createdAt : DateTime
  }

  entity "Lich su danh gia" as EvaluationHistory {
    * PK | id : String
    --
    * FK1 | chatLogId : String
    * | metricName : String
    * | score : Float
    * | evaluatorModel : String
    | reasoning : String
    * | createdAt : DateTime
  }

  entity "Su kien guardrail" as GuardrailEvent {
    * PK | id : String
    --
    | FK1 | chatLogId : String
    * | ruleViolated : String
    * | severity : String
    * | payloadBlocked : String
    * | actionTaken : String
    * | createdAt : DateTime
  }

  entity "Phien ban tri thuc" as KnowledgeVersion {
    * PK | id : String
    --
    * | versionNumber : Int <<UNIQUE>>
    | commitMessage : String
    * | createdAt : DateTime
  }

  entity "Do tuoi moi tri thuc" as KnowledgeFreshness {
    * PK | id : String
    --
    * FK1 | versionId : Int
    * | contentId : String
    * | knowledgeCat : String
    * | lastCheckedAt : DateTime
    * | driftDetected : Boolean
    | sourceHash : String
  }

  entity "Vet kiem toan" as AuditTrail {
    * PK | id : String
    --
    * | actionType : String
    * | actorName : String
    * | description : String
    | ipAddress : String
    * | createdAt : DateTime
  }

  entity "Sieu du lieu cache" as CacheMetadata {
    * PK | id : String
    --
    * | cacheKey : String <<UNIQUE>>
    * | queryText : String
    * | responseJson : String
    * | hitCount : Int
    * | expiresAt : DateTime
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }
}

entity "Tin nhắn AI" as ChatMessage <<External>>

ChatMessage ||--|| AIChatLog : "nhật ký chat"
ModelRegistry ||--o{ AIChatLog : "nhật ký chat"
PromptVersion ||--o{ AIChatLog : "nhật ký chat"
AIChatLog ||--o{ UserFeedback : "phản hồi người dùng"
AIChatLog ||--o{ EvaluationHistory : "lịch sử đánh giá"
AIChatLog ||--o{ GuardrailEvent : "sự kiện guardrail"
KnowledgeVersion ||--o{ KnowledgeFreshness : "nhật ký độ tươi mới"

@enduml
