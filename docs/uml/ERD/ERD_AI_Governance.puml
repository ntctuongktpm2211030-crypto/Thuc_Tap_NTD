@startuml ERD_AI_Governance

left to right direction
skinparam linetype ortho
skinparam ranksep 100
skinparam nodesep 80
hide circle
hide methods
hide stereotype

package "Quản trị & Kiểm toán AI" {
  entity "ModelRegistry" as ModelRegistry {
    * id : String <<PK>>
    --
    * name : String <<UNIQUE>>
    * provider : String
    * type : String
    * version : String
    * isActive : Boolean
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "PromptVersion" as PromptVersion {
    * id : String <<PK>>
    --
    * templateName : String
    * versionHash : String <<UNIQUE>>
    * templateText : String
    * isActive : Boolean
    * createdAt : DateTime
  }

  entity "AIChatLog" as AIChatLog {
    * id : String <<PK>>
    --
    * messageId : String <<FK>> <<UNIQUE>>
    * modelId : String <<FK>>
    * promptId : String <<FK>>
    * query : String
    * llmPrompt : String
    * llmResponse : String
    * similarityScore : Float
    * confidenceScore : Int
    * reliabilityLevel : String
    * groundednessScore : Int
    * claimVerScore : Int
    * retrievedContext : String
    * promptTokens : Int
    * completionTokens : Int
    * totalTokens : Int
    * apiCostUsd : Float
    * latencyMs : Int
    * ttftMs : Int
    * guardrailsBlocked : Boolean
    securityThreatType : String
    unsupportedClaims : Int
    * createdAt : DateTime
  }

  entity "UserFeedback" as UserFeedback {
    * id : String <<PK>>
    --
    * chatLogId : String <<FK>>
    * rating : Int
    comment : String
    correctedText : String
    * isProcessed : Boolean
    * createdAt : DateTime
  }

  entity "EvaluationHistory" as EvaluationHistory {
    * id : String <<PK>>
    --
    * chatLogId : String <<FK>>
    * metricName : String
    * score : Float
    * evaluatorModel : String
    reasoning : String
    * createdAt : DateTime
  }

  entity "GuardrailEvent" as GuardrailEvent {
    * id : String <<PK>>
    --
    chatLogId : String <<FK>>
    * ruleViolated : String
    * severity : String
    * payloadBlocked : String
    * actionTaken : String
    * createdAt : DateTime
  }

  entity "KnowledgeVersion" as KnowledgeVersion {
    * id : String <<PK>>
    --
    * versionNumber : Int <<UNIQUE>>
    commitMessage : String
    * createdAt : DateTime
  }

  entity "KnowledgeFreshness" as KnowledgeFreshness {
    * id : String <<PK>>
    --
    * contentId : String
    * versionId : Int <<FK>>
    * knowledgeCat : String
    * lastCheckedAt : DateTime
    * driftDetected : Boolean
    sourceHash : String
  }

  entity "AuditTrail" as AuditTrail {
    * id : String <<PK>>
    --
    * actionType : String
    * actorName : String
    * description : String
    ipAddress : String
    * createdAt : DateTime
  }
}

entity "ChatMessage" as ChatMessage <<External>>

ChatMessage ||--|| AIChatLog : "chatLog"
ModelRegistry ||--o{ AIChatLog : "chatLogs"
PromptVersion ||--o{ AIChatLog : "chatLogs"
AIChatLog ||--o{ UserFeedback : "userFeedbacks"
AIChatLog ||--o{ EvaluationHistory : "evalHistories"
AIChatLog ||--o{ GuardrailEvent : "guardrailEvents"
KnowledgeVersion ||--o{ KnowledgeFreshness : "freshnessLogs"

@enduml
