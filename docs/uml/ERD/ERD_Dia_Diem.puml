@startuml ERD_Dia_Diem

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Địa điểm & GIS" {
  entity "Destination" as Destination {
    * id : String <<PK>>
    --
    * name : String
    description : String
    * latitude : Float <<INDEX>>
    * longitude : Float <<INDEX>>
    * category : String
    * averageRating : Float
    address : String
    openingHours : String
  }

  entity "CheckIn" as CheckIn {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * destinationId : String <<FK>> <<INDEX>>
    note : String
    * createdAt : DateTime
  }

  entity "SavedPlace" as SavedPlace {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * name : String
    * category : String
    * latitude : Float
    * longitude : Float
    address : String
    imageUrl : String
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "SafetyWarning" as SafetyWarning {
    * id : String <<PK>>
    --
    * type : String
    * description : String
    * latitude : Float <<INDEX>>
    * longitude : Float <<INDEX>>
    * radiusKm : Float
    * createdAt : DateTime
    expiresAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "User" as User <<External>>
entity "TripActivity" as TripActivity <<External>>

User ||--o{ CheckIn : "check-ins"
User ||--o{ SavedPlace : "savedPlaces"

Destination ||--o{ CheckIn : "checkIns"
Destination ||--o{ TripActivity : "activities"

@enduml
