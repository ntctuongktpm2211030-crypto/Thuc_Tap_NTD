@startuml ERD_Cache

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Caching Lớp đệm" {
  entity "Dem he thong" as SystemCache {
    * PK | key : String
    * PK | type : String
    --
    * | value : String
    * | expiresAt : DateTime
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Sieu du lieu cache" as CacheMetadata {
    * PK | id : String
    --
    * | cacheKey : String <<UNIQUE>>
    * | queryText : String
    * | responseJson : String
    * | hitCount : Int
    * | expiresAt : DateTime
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }
}

@enduml
