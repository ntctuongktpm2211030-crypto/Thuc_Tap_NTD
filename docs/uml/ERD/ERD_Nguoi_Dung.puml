@startuml ERD_Nguoi_Dung

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Người dùng & Kết nối" {
  entity "Nguoi dung" as User {
    * PK | id : String
    --
    * | email : String <<UNIQUE>> <<INDEX>>
    * | passwordHash : String
    * | role : UserRole
    * | isVerified : Boolean
    | verificationToken : String
    | resetPasswordToken : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Nguoi theo doi" as Follower {
    * PK | id : String
    --
    * FK1 | followerId : String <<INDEX>>
    * FK2 | followingId : String <<INDEX>>
    * | createdAt : DateTime
  }

  entity "Thong bao" as Notification {
    * PK | id : String
    --
    * FK1 | recipientId : String <<INDEX>>
    * | type : String
    * | content : String
    * | isRead : Boolean
    | targetId : String
    * | createdAt : DateTime
  }

  entity "Vi tri" as Location {
    * PK | id : String
    --
    * FK1 | userId : String <<UNIQUE>>
    * | latitude : Float
    * | longitude : Float
    * | updatedAt : DateTime
  }

  entity "Ghep doi du khach" as TravelerMatch {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * FK2 | matchedUserId : String <<INDEX>>
    * | compatScore : Float <<INDEX>>
    | matchReasons : String[]
    * | status : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Cuoc hoi thoai" as Conversation {
    * PK | id : String
    --
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Tin nhan" as Message {
    * PK | id : String
    --
    * FK1 | conversationId : String <<INDEX>>
    * FK2 | senderId : String
    * | content : String
    * | createdAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Hồ sơ" as Profile <<External>>
entity "Sự kiện" as Event <<External>>

User ||--|| Profile : "hồ sơ"
User ||--o{ Event : "sự kiện tổ chức"

User ||--o{ Follower : "người theo dõi"
User ||--o{ Follower : "đang theo dõi"
User ||--o{ Notification : "thông báo"
User ||--|| Location : "vị trí trực tiếp"
User ||--o{ TravelerMatch : "kết nối"

Conversation ||--o{ Message : "tin nhắn"
User ||--o{ Message : "tin nhắn"
User }o--o{ Conversation : "thành viên"

@enduml
