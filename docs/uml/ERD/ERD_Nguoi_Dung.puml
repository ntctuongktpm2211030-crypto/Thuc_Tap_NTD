@startuml ERD_Nguoi_Dung

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Người dùng & Kết nối" {
  entity "User" as User {
    * id : String <<PK>>
    --
    * email : String <<UNIQUE>> <<INDEX>>
    * passwordHash : String
    * role : UserRole
    * isVerified : Boolean
    verificationToken : String
    resetPasswordToken : String
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "Follower" as Follower {
    * id : String <<PK>>
    --
    * followerId : String <<FK>> <<INDEX>>
    * followingId : String <<FK>> <<INDEX>>
    * createdAt : DateTime
  }

  entity "Notification" as Notification {
    * id : String <<PK>>
    --
    * recipientId : String <<FK>> <<INDEX>>
    * type : String
    * content : String
    * isRead : Boolean
    * createdAt : DateTime
  }

  entity "Location" as Location {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<UNIQUE>>
    * latitude : Float
    * longitude : Float
    * updatedAt : DateTime
  }

  entity "TravelerMatch" as TravelerMatch {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * targetId : String <<FK>> <<INDEX>>
    * matchScore : Float <<INDEX>>
    reasons : String[]
    * status : String
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "Conversation" as Conversation {
    * id : String <<PK>>
    --
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "Message" as Message {
    * id : String <<PK>>
    --
    * conversationId : String <<FK>> <<INDEX>>
    * senderId : String <<FK>>
    * content : String
    * createdAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Profile" as Profile <<External>>
entity "Event" as Event <<External>>

User ||--|| Profile : "profile"
User ||--o{ Event : "organizedEvents"

User ||--o{ Follower : "followers"
User ||--o{ Follower : "following"
User ||--o{ Notification : "notifications"
User ||--|| Location : "liveLocation"
User ||--o{ TravelerMatch : "matches"

Conversation ||--o{ Message : "messages"
User ||--o{ Message : "messages"
User }o--o{ Conversation : "participants"

@enduml
