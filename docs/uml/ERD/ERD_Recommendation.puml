@startuml ERD_Recommendation

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Hệ gợi ý & Đề xuất" {
  entity "Recommendation" as Recommendation {
    * id : String <<PK>>
    --
    * tripId : String <<FK>> <<INDEX>>
    * destinationId : String <<FK>>
    * score : Float
    recommendationReason : String
  }

  entity "UserRecommendation" as UserRecommendation {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * location : String
    destinationId : String <<FK>> <<INDEX>>
    * priority : String
    reason : String
    * type : String
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "FavoriteFood" as FavoriteFood {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * name : String
    region : String
    description : String
    rating : Float
    * createdAt : DateTime
    * updatedAt : DateTime
  }

  entity "TravelHistory" as TravelHistory {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * location : String
    destinationId : String <<FK>> <<INDEX>>
    * time : DateTime
    rating : String
    * cost : Float
    * createdAt : DateTime
  }

  entity "AIHistory" as AIHistory {
    * id : String <<PK>>
    --
    * userId : String <<FK>> <<INDEX>>
    * promptText : String
    * responseJson : String
    * type : String
    * createdAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "User" as User <<External>>
entity "Trip" as Trip <<External>>
entity "Destination" as Destination <<External>>

User ||--o{ UserRecommendation : "recommendations"
User ||--o{ FavoriteFood : "favoriteFoods"
User ||--o{ TravelHistory : "travelHistories"
User ||--o{ AIHistory : "aiHistories"

Trip ||--o{ Recommendation : "recommendations"
Destination ||--o{ Recommendation : "recommendationDestination"
Destination ||--o{ UserRecommendation : "userRecommendationDestination"
Destination ||--o{ TravelHistory : "travelHistoryDestination"

@enduml
