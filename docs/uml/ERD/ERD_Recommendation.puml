@startuml ERD_Recommendation

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
hide circle
hide methods
hide stereotype

package "Module Hệ gợi ý & Đề xuất" {
  entity "Đề xuất chuyến đi" as DeXuatChuyenDi {
    * ma_de_xuat : String <<PK>>
    --
    * ma_chuyen_di : String <<FK>> <<INDEX>>
    * ma_diem_den : String <<FK>>
    * diem_tuong_thich : Float
    ly_do_de_xuat : String
  }

  entity "Đề xuất cá nhân" as DeXuatCaNhan {
    * ma_de_xuat_rieng : String <<PK>>
    --
    * ma_nguoi_dung : String <<FK>> <<INDEX>>
    * dia_diem : String
    ma_diem_den : String <<FK>> <<INDEX>>
    * do_uu_tien : String
    ly_do : String
    * loai_de_xuat : String
    * ngay_tao : DateTime
    * ngay_cap_nhat : DateTime
  }

  entity "Món ăn yêu thích" as MonAnYeuThich {
    * ma_mon_an : String <<PK>>
    --
    * ma_nguoi_dung : String <<FK>> <<INDEX>>
    * ten_mon_an : String
    vung_mien : String
    mo_ta : String
    diem_danh_gia : Float
    * ngay_tao : DateTime
    * ngay_cap_nhat : DateTime
  }

  entity "Lịch sử chuyến đi" as LichSuChuyenDi {
    * ma_lich_su : String <<PK>>
    --
    * ma_nguoi_dung : String <<FK>> <<INDEX>>
    * dia_diem : String
    ma_diem_den : String <<FK>> <<INDEX>>
    * thoi_gian : DateTime
    danh_gia : String
    * chi_phi : Float
    * ngay_tao : DateTime
  }

  entity "Lịch sử gọi AI" as LichSuGoiAI {
    * ma_nhat_ky : String <<PK>>
    --
    * ma_nguoi_dung : String <<FK>> <<INDEX>>
    * cau_lenh_prompt : String
    * ket_qua_json : String
    * loai_tac_vu : String
    * ngay_tao : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as NguoiDung <<External>>
entity "Chuyến đi" as ChuyenDi <<External>>
entity "Điểm đến" as DiemDen <<External>>

NguoiDung ||--o{ DeXuatCaNhan : "nhận đề xuất"
NguoiDung ||--o{ MonAnYeuThich : "thích ăn"
NguoiDung ||--o{ LichSuChuyenDi : "lưu"
NguoiDung ||--o{ LichSuGoiAI : "sử dụng"

ChuyenDi ||--o{ DeXuatChuyenDi : "gợi ý cho"
DiemDen ||--o{ DeXuatChuyenDi : "địa điểm đề xuất"
DiemDen ||--o{ DeXuatCaNhan : "địa danh liên kết"
DiemDen ||--o{ LichSuChuyenDi : "địa danh liên kết"

@enduml
