@startuml ERD_Recommendation

left to right direction
skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 70
skinparam monochrome true
hide circle
hide methods
hide stereotype

package "Module Hệ gợi ý & Đề xuất" {
  entity "De xuat" as Recommendation {
    * PK | id : String
    --
    * FK1 | tripId : String <<INDEX>>
    * FK2 | destinationId : String
    * | score : Float
    | recommendationReason : String
  }

  entity "De xuat nguoi dung" as UserRecommendation {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | location : String
    | FK2 | destinationId : String <<INDEX>>
    * | priority : String
    | reason : String
    * | type : String
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Mon an yeu thich" as FavoriteFood {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | name : String
    | region : String
    | description : String
    | rating : Float
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Lich su du lich" as TravelHistory {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | location : String
    | FK2 | destinationId : String <<INDEX>>
    * | time : DateTime
    | rating : String
    * | cost : Float
    * | createdAt : DateTime
    * | updatedAt : DateTime
  }

  entity "Lich su AI" as AIHistory {
    * PK | id : String
    --
    * FK1 | userId : String <<INDEX>>
    * | promptText : String
    * | responseJson : String
    * | type : String
    * | createdAt : DateTime
  }
}

' ─── LIÊN KẾT NGOÀI MODULE (REFERENCES) ───
entity "Người dùng" as User <<External>>
entity "Chuyến đi" as Trip <<External>>
entity "Điểm đến" as Destination <<External>>

User ||--o{ UserRecommendation : "đề xuất"
User ||--o{ FavoriteFood : "món ăn yêu thích"
User ||--o{ TravelHistory : "lịch sử du lịch"
User ||--o{ AIHistory : "lịch sử AI"

Trip ||--o{ Recommendation : "đề xuất"
Destination ||--o{ Recommendation : "đề xuất điểm đến"
Destination ||--o{ UserRecommendation : "đề xuất điểm đến"
Destination ||--o{ TravelHistory : "lịch sử điểm đến"

@enduml
