@startuml UseCase_Realtime
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' Actors
actor "Người dùng đăng ký\n(User)" as User
actor "Quản trị viên\n(Administrator)" as Admin

' External / Supporting Systems
actor "WebSocket Server" as WS <<System>>
actor "Push Notification Service" as PushNotification <<System>>

rectangle "Phân hệ Tính năng Thời gian thực (Real-time Features)" {
  usecase "Nhắn tin trực tiếp thời gian thực" as UC_LiveChat
  usecase "Truyền phản hồi AI dạng stream" as UC_StreamAI
  usecase "Hiển thị trạng thái đang nhập (Typing)" as UC_Typing
  usecase "Cập nhật trạng thái trực tuyến (Online)" as UC_OnlineStatus
  
  usecase "Thông báo trực tiếp tức thời" as UC_LiveNotif
  usecase "Nhận thông báo tương tác" as UC_ReceiveNotif
  usecase "Nhận thông báo khẩn từ Admin" as UC_AdminAnnouncement
  
  usecase "Cập nhật bảng tin tức thời" as UC_LiveFeed
  usecase "Bình luận tức thời" as UC_InstantComment
  usecase "Thích bài viết tức thời" as UC_InstantLike
}

' User Associations
User --> UC_LiveChat
User --> UC_StreamAI
User --> UC_LiveNotif
User --> UC_ReceiveNotif
User --> UC_LiveFeed
User --> UC_InstantComment
User --> UC_InstantLike

' Admin Associations
Admin --> UC_LiveChat
Admin --> UC_AdminAnnouncement

' Relationships (include / extend)
UC_LiveChat ..> UC_Typing : <<extend>>
UC_LiveChat ..> UC_OnlineStatus : <<include>>
UC_LiveNotif ..> UC_ReceiveNotif : <<include>>
UC_AdminAnnouncement ..> UC_LiveNotif : <<include>>

' WebSocket Server Mappings
UC_LiveChat --> WS
UC_StreamAI --> WS
UC_LiveFeed --> WS
UC_InstantComment --> WS
UC_InstantLike --> WS

' Push Notification Mappings
UC_LiveNotif --> PushNotification
@enduml
