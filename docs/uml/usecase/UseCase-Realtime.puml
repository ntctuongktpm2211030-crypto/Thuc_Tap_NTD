@startuml UseCase_Realtime
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' Actors
actor "Người dùng đăng ký\n(User)" as User

rectangle "Tính năng Thời gian thực (Real-time Features)" {
  usecase "Nhắn tin trực tiếp thời gian thực\n(Real-time Messaging)" as UC_LiveChat
  usecase "Truyền phản hồi AI dạng stream\n(Stream AI Responses)" as UC_StreamAI
  usecase "Hiển thị trạng thái đang nhập\n(Typing Indicator)" as UC_Typing
  usecase "Cập nhật trạng thái trực tuyến\n(Online Status)" as UC_OnlineStatus
  
  usecase "Thông báo trực tiếp tức thời\n(Instant Notification)" as UC_LiveNotif
  usecase "Nhận thông báo tương tác\n(Receive Interactive Alerts)" as UC_ReceiveNotif
  
  usecase "Cập nhật bảng tin tức thời\n(Instant Feed Updates)" as UC_LiveFeed
  usecase "Bình luận tức thời\n(Instant Commenting)" as UC_InstantComment
  usecase "Thích bài viết tức thời\n(Instant Liking)" as UC_InstantLike
}

' User Associations
User -- UC_LiveChat
User -- UC_StreamAI
User -- UC_LiveNotif
User -- UC_ReceiveNotif
User -- UC_LiveFeed
User -- UC_InstantComment
User -- UC_InstantLike

' Relationships (include / extend)
UC_LiveChat <.. UC_Typing : <<extend>>
UC_LiveChat ..> UC_OnlineStatus : <<include>>
UC_LiveNotif ..> UC_ReceiveNotif : <<include>>

@enduml
