@startuml UseCase_Authentication
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' ==========================================
' 1. ACTORS DEFINITIONS
' ==========================================
actor "Khách vãng lai\n(Guest)" as Guest
actor "Người dùng đăng ký\n(Registered User)" as RegisteredUser

actor "SMTP Mail Server" as SMTP <<System>>
actor "Firebase Auth" as Firebase <<System>>
actor "vietnamadminunits API" as AdminUnits <<System>>

RegisteredUser -|> Guest

' ==========================================
' 2. SYSTEM BOUNDARY & AUTH USE CASES
' ==========================================
rectangle "Phân hệ Xác thực & Thành viên (Authentication & Profile)" as AuthModule {

  usecase "Đăng ký tài khoản\n(Register)" as UC_Reg
  usecase "Xác thực tài khoản qua Email\n(Verify Email)" as UC_Verify
  usecase "Đăng nhập tài khoản\n(Log In)" as UC_Login
  usecase "Đăng nhập truyền thống\n(Password Log In)" as UC_PassLogin
  usecase "Đăng nhập Google SSO\n(Google SSO Log In)" as UC_GLogin
  
  usecase "Quản lý hồ sơ & sở thích\n(Manage Profile & Preferences)" as UC_Pref
  usecase "Tìm kiếm thành viên\n(Search Profiles)" as UC_Search
  usecase "Theo dõi thành viên khác\n(Follow Members)" as UC_Follow
  usecase "Hủy theo dõi thành viên\n(Unfollow Members)" as UC_Unfollow
  
  usecase "Xem lịch sử thông báo\n(View Notifications)" as UC_Notif
  usecase "Đánh dấu đã đọc tất cả\n(Mark All as Read)" as UC_MarkRead

  ' Generalizations
  UC_PassLogin -|> UC_Login
  UC_GLogin -|> UC_Login
  
  ' Extends / Includes
  UC_Follow <.. UC_Unfollow : <<extend>>
  UC_Notif <.. UC_MarkRead : <<extend>>
}

' ==========================================
' 3. ASSOCIATIONS
' ==========================================
Guest -- UC_Reg
Guest -- UC_Verify
Guest -- UC_Login
Guest -- UC_Search

RegisteredUser -- UC_Pref
RegisteredUser -- UC_Follow
RegisteredUser -- UC_Notif

UC_Reg -- SMTP
UC_Verify -- SMTP
UC_Login -- Firebase
UC_Pref -- AdminUnits

@enduml
