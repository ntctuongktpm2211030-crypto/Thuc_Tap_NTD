@startuml UseCase_AI
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' ==========================================
' 1. ACTORS DEFINITIONS
' ==========================================
actor "Người dùng đăng ký" as RegisteredUser
actor "OpenAI API\n(LLM Service)" as LLM <<System>>

' ==========================================
' 2. SYSTEM BOUNDARY & AI USE CASES
' ==========================================
rectangle "Phân hệ Trợ lý ảo AI & RAG (AI Chatbot & RAG)" as AIModule {
  
  package "Quản lý hội thoại (Conversation)" {
    usecase "Khởi tạo cuộc hội thoại mới\n(Create New Chat Session)" as UC_StartConv
    usecase "Xem danh sách lịch sử cuộc hội thoại\n(List Chat Conversations)" as UC_ConvHistory
    usecase "Xem nội dung chi tiết cuộc hội thoại\n(View Chat Details)" as UC_ViewChatDetails
    usecase "Xóa phiên hội thoại chat\n(Delete Chat Conversation)" as UC_DeleteConv
  }
  
  package "Tương tác Chatbot & CIM (Chat & Intelligence)" {
    usecase "Gửi tin nhắn trò chuyện với Trợ lý ảo\n(Send Message to Chatbot)" as UC_AskQuestion
    usecase "Nhận phản hồi từ Trợ lý ảo\n(Receive AI Response)" as UC_ReceiveAnswer
    usecase "Yêu cầu chatbot sinh lại câu trả lời khác\n(Regenerate AI Response)" as UC_RegenResponse
    usecase "Đánh giá chất lượng câu trả lời AI\n(Rate AI Chat Response)" as UC_RateResponse
  }
  
  package "Bộ nhớ AI (AI Memory)" {
    usecase "Xem cấu hình Bộ nhớ AI\n(View AI Memory Configuration)" as UC_ViewMemory
    usecase "Cập nhật cấu hình Bộ nhớ AI\n(Update AI Memory)" as UC_UpdateMemory
    usecase "Xóa cấu hình Bộ nhớ AI\n(Clear AI Memory)" as UC_ClearMemory
  }
  
  package "Cẩm nang ẩm thực (Favorite Foods)" {
    usecase "Xem danh sách món ẩm thực yêu thích\n(View Favorite Foods List)" as UC_ViewFoods
    usecase "Lưu món đặc sản vào mục yêu thích\n(Add Favorite Food)" as UC_AddFood
    usecase "Cập nhật / Xóa món ăn đã lưu\n(Update/Delete Favorite Food)" as UC_ManageFood
  }

  ' Notes describing internal automated pipelines (instead of functional decomposition)
  note right of UC_AskQuestion
    Pipeline xử lý tự động:
    - Guardrails Check
  end note

  note right of UC_ReceiveAnswer
    Pipeline xử lý tự động:
    - Emotion Analysis
    - Rule Override
    - Answer First, Ask Later
    - Fact Verification
  end note

  ' Relationships (include / extend)
  UC_AskQuestion <.. UC_RegenResponse : <<extend>>
  UC_ReceiveAnswer <.. UC_RateResponse : <<extend>>
  
  UC_ViewMemory <.. UC_UpdateMemory : <<extend>>
  UC_ViewMemory <.. UC_ClearMemory : <<extend>>
  UC_ViewFoods <.. UC_ManageFood : <<extend>>
}

' ==========================================
' 3. ASSOCIATIONS
' ==========================================
RegisteredUser -- UC_StartConv
RegisteredUser -- UC_ConvHistory
RegisteredUser -- UC_ViewChatDetails
RegisteredUser -- UC_DeleteConv

RegisteredUser -- UC_AskQuestion
RegisteredUser -- UC_ReceiveAnswer
RegisteredUser -- UC_RateResponse

RegisteredUser -- UC_ViewMemory
RegisteredUser -- UC_ViewFoods
RegisteredUser -- UC_AddFood

UC_AskQuestion -- LLM
UC_RegenResponse -- LLM

@enduml
