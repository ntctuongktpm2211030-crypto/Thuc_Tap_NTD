@startuml UseCase_Social
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' ==========================================
' 1. ACTORS DEFINITIONS
' ==========================================
actor "Khách vãng lai\n(Guest)" as Guest
actor "Người dùng đăng ký\n(Registered User)" as RegisteredUser

actor "Supabase Storage" as SupabaseStorage <<System>>
actor "Notification Service" as PushNotification <<System>>

RegisteredUser -|> Guest

' ==========================================
' 2. SYSTEM BOUNDARY & SOCIAL USE CASES
' ==========================================
rectangle "Phân hệ Mạng xã hội & Cộng đồng (Social & Community)" as SocialModule {
  
  package "Bài đăng & Tương tác (Posts)" {
    usecase "Xem bảng tin cộng đồng\n(Browse Community Feed)" as UC_ViewFeed
    usecase "Xem chi tiết bài viết\n(View Post Details)" as UC_ViewPostDetail
    usecase "Tạo bài viết mới kèm hình ảnh\n(Create Post with Media)" as UC_CreatePost
    usecase "Tải hình ảnh bài đăng\n(Upload Post Image)" as UC_UploadImage
    usecase "Chỉnh sửa bài viết cá nhân\n(Edit Post)" as UC_EditPost
    usecase "Xóa bài viết cá nhân\n(Delete Post)" as UC_DeletePost
    
    usecase "Thích bài viết\n(Like Post)" as UC_Like
    usecase "Bỏ thích bài viết\n(Unlike Post)" as UC_Unlike
    usecase "Đánh dấu lưu trữ bài viết\n(Bookmark Post)" as UC_Bookmark
    usecase "Xem danh sách đã lưu trữ\n(View Bookmarked Posts)" as UC_ViewSaved
    
    usecase "Xem bình luận bài viết\n(List Comments on Post)" as UC_ListComments
    usecase "Viết bình luận bài viết\n(Write Comment on Post)" as UC_Comment
    usecase "Viết phản hồi bình luận\n(Reply to Comment)" as UC_Reply
  }

  ' Relationships (include / extend)
  UC_CreatePost ..> UC_UploadImage : <<include>>
  UC_Comment <.. UC_Reply : <<extend>>
}

' ==========================================
' 3. ASSOCIATIONS
' ==========================================
Guest -- UC_ViewFeed
Guest -- UC_ViewPostDetail
Guest -- UC_ListComments

RegisteredUser -- UC_CreatePost
RegisteredUser -- UC_EditPost
RegisteredUser -- UC_DeletePost
RegisteredUser -- UC_Like
RegisteredUser -- UC_Unlike
RegisteredUser -- UC_Bookmark
RegisteredUser -- UC_ViewSaved
RegisteredUser -- UC_Comment

UC_UploadImage -- SupabaseStorage

@enduml

