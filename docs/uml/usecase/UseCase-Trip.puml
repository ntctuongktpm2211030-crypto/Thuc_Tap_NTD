@startuml UseCase_Trip
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' ==========================================
' 1. ACTORS DEFINITIONS
' ==========================================
actor "Người dùng đăng ký\n(Registered User)" as RegisteredUser

actor "OpenAI API\n(LLM Service)" as OpenAI <<System>>

' ==========================================
' 2. SYSTEM BOUNDARY & TRIP USE CASES
' ==========================================
rectangle "Phân hệ Lập lịch trình & Hành trình (Trip Planning)" as TripModule {
  
  package "Kế hoạch chuyến đi (Trips)" {
    usecase "Xem danh sách chuyến đi\n(List Personal Trips)" as UC_ListTrips
    usecase "Xem chi tiết chuyến đi\n(View Trip Details)" as UC_ViewTrip
    usecase "Tạo chuyến đi thủ công\n(Create Trip Manually)" as UC_CreateTrip
    usecase "Cập nhật/Tái tạo một phần lịch trình bằng AI\n(Update/Regenerate Part of AI Itinerary)" as UC_UpdateTrip
    usecase "Xóa chuyến đi\n(Delete Trip)" as UC_DeleteTrip
    
    
    usecase "Tự động tạo lịch trình bằng AI\n(Generate AI Trip Itinerary)" as UC_AITrip
    usecase "Tối ưu hóa thứ tự lộ trình (TSP)\n(Optimize Route Sequence)" as UC_OptimizeRoute
  }
  
  package "Hành trình tự do (Custom Itineraries)" {
    usecase "Tạo hành trình tự do mới\n(Create Custom Itinerary)" as UC_CreateItinerary
    usecase "Thêm ngày vào hành trình\n(Add Day to Itinerary)" as UC_AddDay
    usecase "Thêm hoạt động vào ngày\n(Add Activity to Day)" as UC_AddActivity
    usecase "Cập nhật hoạt động hành trình\n(Update Itinerary Activity)" as UC_UpdateActivity
    usecase "Xóa hoạt động hành trình\n(Delete Itinerary Activity)" as UC_DeleteActivity
  }
  
  package "Nhật ký di chuyển (Travel History)" {
    usecase "Xem nhật ký di chuyển thực tế\n(List Travel Histories)" as UC_ListHistory
    usecase "Tạo bản ghi lịch sử du lịch\n(Create Travel History Entry)" as UC_CreateHistory
    usecase "Cập nhật bản ghi lịch sử\n(Update Travel History Entry)" as UC_UpdateHistory
    usecase "Xóa bản ghi lịch sử\n(Delete Travel History Entry)" as UC_DeleteHistory
  }
  
  package "Đề xuất điểm đến (AI Recommendations)" {
    usecase "Xem đề xuất cá nhân hóa từ AI\n(View AI Recommendations)" as UC_ViewRecommend
    usecase "Lưu địa điểm đề xuất vào chuyến đi\n(Save Recommendations to Trip)" as UC_SaveRecommend
  }

  ' Relationships (include / extend)
  UC_CreateTrip <.. UC_AITrip : <<extend>>
  UC_AITrip <.. UC_UpdateTrip : <<extend>>
  UC_AITrip <.. UC_OptimizeRoute : <<extend>>
  

  
  UC_ViewRecommend <.. UC_SaveRecommend : <<extend>>
}

' ==========================================
' 3. ASSOCIATIONS
' ==========================================
RegisteredUser -- UC_ViewTrip
RegisteredUser -- UC_ListTrips
RegisteredUser -- UC_CreateTrip
RegisteredUser -- UC_UpdateTrip
RegisteredUser -- UC_DeleteTrip

RegisteredUser -- UC_CreateItinerary
RegisteredUser -- UC_AddDay
RegisteredUser -- UC_AddActivity
RegisteredUser -- UC_UpdateActivity
RegisteredUser -- UC_DeleteActivity

RegisteredUser -- UC_ListHistory
RegisteredUser -- UC_CreateHistory
RegisteredUser -- UC_UpdateHistory
RegisteredUser -- UC_DeleteHistory

RegisteredUser -- UC_ViewRecommend

UC_AITrip -- OpenAI
UC_ViewRecommend -- OpenAI

@enduml
