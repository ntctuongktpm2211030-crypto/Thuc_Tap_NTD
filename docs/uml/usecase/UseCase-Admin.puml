@startuml UseCase-AI-Chatbot
left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #FFF9D6
    BorderColor #C0392B
}

actor "Người dùng đã đăng ký" as User
actor "LLM Service" as LLM <<System>>

rectangle "AI Chatbot Module" {

    package "Quản lý hội thoại" {

        usecase "Khởi tạo cuộc\nhội thoại mới" as UC_NewChat

        usecase "Gửi tin nhắn\ncho trợ lý AI" as UC_Send

        usecase "Xem lịch sử\ntrò chuyện" as UC_History

        usecase "Xem chi tiết\ncuộc hội thoại" as UC_Detail

        usecase "Xóa cuộc\nhội thoại" as UC_Delete

        usecase "Yêu cầu sinh lại\ncâu trả lời" as UC_Regen

        usecase "Đánh giá\ncâu trả lời AI" as UC_Rating
    }

    package "Bộ nhớ AI" {

        usecase "Quản lý\nbộ nhớ AI" as UC_Memory

        usecase "Xem cấu hình\nbộ nhớ AI" as UC_ViewMemory

        usecase "Cập nhật cấu hình\nbộ nhớ AI" as UC_EditMemory

        usecase "Xóa cấu hình\nbộ nhớ AI" as UC_DeleteMemory
    }

    package "Sở thích người dùng" {

        usecase "Quản lý danh sách\nmón ăn yêu thích" as UC_Favorite
    }
}

'==========================
' Association
'==========================

User --> UC_NewChat
User --> UC_Send
User --> UC_History
User --> UC_Detail
User --> UC_Delete

User --> UC_Memory
User --> UC_Favorite

LLM --> UC_Send

'==========================
' Include
'==========================

UC_Memory ..> UC_ViewMemory : <<include>>
UC_Memory ..> UC_EditMemory : <<include>>
UC_Memory ..> UC_DeleteMemory : <<include>>

'==========================
' Extend
'==========================

UC_Regen ..> UC_Send : <<extend>>

UC_Rating ..> UC_Send : <<extend>>

@enduml