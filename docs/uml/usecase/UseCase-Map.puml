@startuml UseCase_Map
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' ==========================================
' 1. ACTORS DEFINITIONS
' ==========================================
actor "Khách vãng lai\n(Guest)" as Guest
actor "Người dùng đăng ký\n(Registered User)" as RegisteredUser

actor "OpenStreetMap\n(OSM Service)" as OSM <<System>>
actor "OpenAI API\n(LLM Service)" as OpenAI <<System>>
RegisteredUser -|> Guest

' ==========================================
' 2. SYSTEM BOUNDARY & MAP USE CASES
' ==========================================
rectangle "Bản đồ Tương tác & GIS (Interactive Map & GIS)" as MapModule {
  
  package "Điều hướng & Tìm kiếm (Navigation & Search)" {
    usecase "Xem & di chuyển bản đồ\n(View & Navigate Map)" as UC_ViewMap
    usecase "Tìm kiếm vị trí địa lý\n(Search Location)" as UC_SearchLocation
    usecase "Lọc danh mục & đánh giá\n(Filter Categories & Ratings)" as UC_FilterCategories
    usecase "Xem chi tiết địa điểm\n(View Attraction Details)" as UC_ViewAttractionDetail
  }
  
  package "Định vị & Theo dõi Live (Live Tracking)" {
    usecase "Cập nhật vị trí hiện tại lên bản đồ live\n(Update Current Live Location)" as UC_GetCurrentLocation
    usecase "Xem vị trí live của bạn bè trên bản đồ\n(Track Friends Live Locations)" as UC_TrackFriends
    usecase "Tìm bạn lân cận chia sẻ vị trí (100km)\n(Find Nearby Users - 100km)" as UC_FindNearbyUsers
  }
  
  package "Tương tác & Check-in (Check-in & Offline)" {
    usecase "Thực hiện check-in địa điểm\n(Perform Check-in)" as UC_PerformCheckin
    usecase "Xem bản đồ nhiệt check-in\n(View Heatmap check-ins)" as UC_ViewHeatmap
    usecase "Tải bản đồ ngoại tuyến\n(Cache Map Tiles)" as UC_CacheMap
    usecase "Tối ưu lộ trình di chuyển du lịch\n(Optimize Local Route - TSP)" as UC_OptimizeLocalRoute
  }
  
  package "Trợ lý bản đồ AI (AI Map Assistant)" {
    usecase "Xem gợi ý điểm dừng từ trợ lý bản đồ AI\n(Get AI Recommendations on Map)" as UC_AIRecommendations
    usecase "Hỏi trợ lý ảo về địa điểm được chọn\n(Ask AI Assistant about Location)" as UC_AIAssistant
  }

  ' Relationships (include / extend)
  UC_GetCurrentLocation <.. UC_TrackFriends : <<extend>>

  UC_GetCurrentLocation <.. UC_FindNearbyUsers : <<extend>>
}

' ==========================================
' 3. ASSOCIATIONS
' ==========================================
Guest -- UC_ViewMap
Guest -- UC_SearchLocation
Guest -- UC_FilterCategories
Guest -- UC_ViewAttractionDetail
Guest -- UC_ViewHeatmap

RegisteredUser -- UC_GetCurrentLocation
RegisteredUser -- UC_TrackFriends
RegisteredUser -- UC_FindNearbyUsers
RegisteredUser -- UC_PerformCheckin
RegisteredUser -- UC_CacheMap
RegisteredUser -- UC_OptimizeLocalRoute
RegisteredUser -- UC_AIRecommendations
RegisteredUser -- UC_AIAssistant

UC_ViewMap -- OSM
UC_SearchLocation -- OSM
UC_AIRecommendations -- OpenAI
UC_AIAssistant -- OpenAI

@enduml
