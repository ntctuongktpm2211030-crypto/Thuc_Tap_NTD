@startuml UseCase_Master
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' ==========================================
' 1. ACTORS DEFINITIONS
' ==========================================

package "Tác nhân con người (Human Actors)" {
  actor "Khách vãng lai\n(Guest)" as Guest
  actor "Người dùng đăng ký\n(Registered User)" as RegisteredUser
}

package "Hệ thống & Dịch vụ ngoại vi (External Systems)" {
  actor "Firebase Auth" as Firebase <<System>>
  actor "OpenStreetMap\n(Map Service)" as OSM <<System>>
  actor "SMTP Mail Server" as SMTP <<System>>
  actor "OpenAI API\n(LLM Service)" as OpenAI <<System>>
  actor "vietnamadminunits API" as AdminUnits <<System>>
  actor "Supabase Storage" as Storage <<System>>
}

' Actor Inheritance
RegisteredUser -|> Guest

' ==========================================
' 2. SYSTEM BOUNDARY & USE CASES
' ==========================================

rectangle "Nền tảng Trợ lý ảo Du lịch Thông minh Terraholic" as Terraholic {

  ' --- Phân hệ Xác thực & Thành viên ---
  package "Xác thực & Hồ sơ (Authentication & Profile)" {
    usecase "Đăng ký tài khoản\n(Register)" as UC_Auth_Reg
    usecase "Xác thực tài khoản qua Email\n(Verify Email)" as UC_Auth_Verify
    usecase "Đăng nhập tài khoản\n(Log In)" as UC_Auth_Login
    usecase "Đăng nhập truyền thống\n(Password Log In)" as UC_Auth_PassLogin
    usecase "Đăng nhập Google SSO\n(Google SSO Log In)" as UC_Auth_GLogin
    usecase "Quản lý hồ sơ & sở thích\n(Manage Profile)" as UC_Auth_Pref
    usecase "Theo dõi thành viên khác\n(Follow Members)" as UC_Auth_Follow
  }

  ' --- Phân hệ Lập lịch trình ---
  package "Lập lịch trình & Hành trình (Trip Planning)" {
    usecase "Quản lý chuyến đi\n(Manage Trips)" as UC_Trip_Manage
    usecase "Tạo lịch trình qua AI\n(AI Itinerary Generation)" as UC_Trip_AI
    usecase "Tối ưu lộ trình TSP\n(Route Optimization)" as UC_Trip_TSP
    usecase "Quản lý lịch sử đi lại\n(Manage Travel History)" as UC_Trip_History
    usecase "Tạo hành trình tự do mới\n(Create Custom Itinerary)" as UC_Trip_Custom
    usecase "Quản lý hoạt động hành trình\n(Manage Custom Activities)" as UC_Trip_Act
  }

  ' --- Phân hệ Mạng xã hội ---
  package "Mạng xã hội & Cộng đồng (Social & Community)" {
    usecase "Xem bảng tin cộng đồng\n(Browse Feed)" as UC_Soc_Feed
    usecase "Quản lý bài viết chia sẻ\n(Manage Posts)" as UC_Soc_Posts
    usecase "Thích/Bỏ thích bài đăng\n(Like/Unlike Posts)" as UC_Soc_Like
    usecase "Bình luận bài viết\n(Comment on Posts)" as UC_Soc_Comment
    usecase "Lưu trữ bài đăng\n(Bookmark Posts)" as UC_Soc_Bookmark
  }

  ' --- Phân hệ Bản đồ ---
  package "Bản đồ tương tác & GIS (Interactive Map & GIS)" {
    usecase "Xem & di chuyển bản đồ\n(View & Pan Map)" as UC_Map_View
    usecase "Thay đổi bản đồ nền\n(Switch Base Map)" as UC_Map_Style
    usecase "Tìm kiếm vị trí\n(Search Location)" as UC_Map_Search
    usecase "Lọc danh mục địa điểm\n(Filter Categories)" as UC_Map_Filter
    usecase "Xem chi tiết địa điểm\n(View Attraction Details)" as UC_Map_Detail
    usecase "Định vị & Chia sẻ vị trí live\n(Live Location Tracking)" as UC_Map_Live
    usecase "Xem chỉ đường lộ trình\n(View Route Directions)" as UC_Map_Route
    usecase "Thực hiện check-in địa điểm\n(Perform Check-in)" as UC_Map_Checkin
    usecase "Tạo sự kiện local\n(Create Local Event)" as UC_Map_CreateEvent
    usecase "Xem sự kiện địa phương\n(View Local Events)" as UC_Map_ViewEvents
  }

  ' --- Phân hệ Trợ lý ảo AI ---
  package "Trợ lý ảo AI & RAG (AI Chatbot & RAG)" {
    usecase "Chat với trợ lý ảo đa Agent\n(Chat with AI Assistant)" as UC_AI_Chat
    usecase "Quản lý phiên hội thoại\n(Manage Chat Sessions)" as UC_AI_Conv
    usecase "Tái tạo phản hồi đa phiên bản\n(Regenerate Response)" as UC_AI_Regen
    usecase "Đánh giá phản hồi AI\n(Rate AI Answer)" as UC_AI_Feedback
    usecase "Quản lý món ăn yêu thích\n(Manage Favorite Foods)" as UC_AI_Food
  }


  ' ==========================================
  ' RELATIONSHIPS BETWEEN USE CASES
  ' ==========================================
  
  ' Extends
  UC_Trip_AI ..> UC_Trip_Manage : <<extend>>
  UC_Trip_TSP ..> UC_Trip_Manage : <<extend>>

  ' Generalizations
  UC_Auth_PassLogin -|> UC_Auth_Login
  UC_Auth_GLogin -|> UC_Auth_Login
}

' ==========================================
' 3. ASSOCIATIONS (ACTORS -> USE CASES)
' ==========================================

' Guest Associations
Guest -- UC_Auth_Reg
Guest -- UC_Auth_Verify
Guest -- UC_Auth_Login
Guest -- UC_Soc_Feed
Guest -- UC_Map_View
Guest -- UC_Map_Style
Guest -- UC_Map_Search
Guest -- UC_Map_Filter
Guest -- UC_Map_Detail
Guest -- UC_Map_ViewEvents

' Registered User Associations
RegisteredUser -- UC_Auth_Pref
RegisteredUser -- UC_Auth_Follow
RegisteredUser -- UC_Trip_Manage
RegisteredUser -- UC_Trip_History
RegisteredUser -- UC_Trip_Custom
RegisteredUser -- UC_Trip_Act
RegisteredUser -- UC_Soc_Posts
RegisteredUser -- UC_Soc_Like
RegisteredUser -- UC_Soc_Comment
RegisteredUser -- UC_Soc_Bookmark
RegisteredUser -- UC_Map_Live
RegisteredUser -- UC_Map_Route
RegisteredUser -- UC_Map_Checkin
RegisteredUser -- UC_Map_CreateEvent
RegisteredUser -- UC_AI_Chat
RegisteredUser -- UC_AI_Conv
RegisteredUser -- UC_AI_Regen
RegisteredUser -- UC_AI_Feedback
RegisteredUser -- UC_AI_Food

' External Systems Connections
UC_Auth_Reg -- SMTP
UC_Auth_Verify -- SMTP
UC_Auth_Login -- Firebase
UC_Auth_Pref -- AdminUnits

UC_Trip_AI -- OpenAI
UC_Soc_Posts -- Storage

UC_Map_View -- OSM
UC_Map_Style -- OSM
UC_Map_Search -- OSM
UC_Map_Route -- OSM
UC_Map_Checkin -- Storage

UC_AI_Chat -- OpenAI
UC_AI_Regen -- OpenAI

@enduml
