@startuml UseCase_Master
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam linetype ortho

' Actors
actor "Khách vãng lai\n(Guest)" as Guest
actor "Khách du lịch\n(Tourist)" as Tourist
actor "Người dùng đăng ký\n(Registered User)" as RegisteredUser
actor "Quản trị viên\n(Administrator)" as Admin

' External Systems Package
package "Hệ thống ngoại vi\n(External Systems)" {
  actor "Google OAuth" as GoogleOAuth <<System>>
  actor "OpenStreetMap" as OSM <<System>>
  actor "Weather API" as WeatherAPI <<System>>
  actor "LLM Service" as LLM <<System>>
  actor "Email Service" as EmailService <<System>>
}

' Actor Inheritance
Tourist -|> Guest
RegisteredUser -|> Tourist
Admin -|> RegisteredUser

rectangle "Hệ thống Thông tin Du lịch Việt Nam (Vietnam Tourism System)" {
  usecase "Authentication & Profile\n(Xác thực & Hồ sơ)" as Sub_Auth
  usecase "Trip Planning & Itinerary\n(Lập kế hoạch & Hành trình)" as Sub_Trip
  usecase "Community & Social Feed\n(Mạng xã hội & Cộng đồng)" as Sub_Social
  usecase "Interactive Map & GIS\n(Bản đồ tương tác & GIS)" as Sub_Map
  usecase "AI Chatbot & RAG\n(Trợ lý ảo & Tra cứu tri thức)" as Sub_AI
  usecase "System Administration\n(Quản trị hệ thống)" as Sub_Admin
}

' Guest Associations
Guest --> Sub_Auth
Guest --> Sub_Map

' Tourist Associations
Tourist --> Sub_Trip

' Registered User Associations
RegisteredUser --> Sub_Social
RegisteredUser --> Sub_AI

' Admin Associations
Admin --> Sub_Admin

' External System Associations
Sub_Auth --> GoogleOAuth
Sub_Auth --> EmailService
Sub_Trip --> WeatherAPI
Sub_Map --> OSM
Sub_AI --> LLM
@enduml
