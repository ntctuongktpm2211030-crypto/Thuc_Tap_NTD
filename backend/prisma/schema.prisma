// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

enum UserRole {
  USER
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  passwordHash         String
  role                 UserRole           @default(USER)
  isVerified           Boolean            @default(false)
  verificationToken    String?
  resetPasswordToken   String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  
  profile              Profile?
  preferences          TravelPreferences?
  trips                Trip[]             @relation("UserTrips")
  posts                Post[]
  comments             Comment[]
  likes                Like[]
  bookmarks            Bookmark[]
  checkIns             CheckIn[]
  notifications        Notification[]
  aiHistories          AIHistory[]
  liveLocation         Location?          @relation("UserLiveLocation")
  chatbotConversations ChatConversation[]
  aiMemory             AIMemory?
  userRecommendations  UserRecommendation[]
  travelHistories      TravelHistory[]
  favoriteFoods        FavoriteFood[]
  savedPlaces          SavedPlace[]
  aiFeedbacks          AIFeedback[]
  
  // Self-referencing many-to-many for followers
  followers            Follower[]         @relation("Following")
  following            Follower[]         @relation("Follower")
  
  // Chat relationships
  conversations        Conversation[]     @relation("ConversationParticipants")
  messages             Message[]

  // New model relationships
  journeys             Journey[]
  locationHistory      LocationHistory[]
  organizedEvents      Event[]            @relation("EventOrganizer")
  eventAttendances     EventAttendee[]
  travelerMatchesUser  TravelerMatch[]    @relation("TravelerMatchUser")
  travelerMatchesTarget TravelerMatch[]   @relation("TravelerMatchTarget")

  @@index([email])
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  fullName     String
  avatarUrl    String?
  coverUrl     String?
  bio          String?
  phoneNumber  String?
  homeLocation String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TravelPreferences {
  id               String   @id @default(uuid())
  userId           String   @unique
  preferredPace    String   // "slow", "moderate", "fast"
  dailyBudget      Float
  activities       String[] // e.g. ["nature", "culture", "food"]
  destinationTypes String[] // e.g. ["beach", "mountain", "city"]
  foodPreferences  String[] // e.g. ["streetfood", "vegetarian", "fine-dining"]
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TripStatus {
  DRAFT_AI      // Lịch trình nháp sinh bởi trợ lý AI
  DRAFT_USER    // Lịch trình nháp do người dùng tự tạo
  CONFIRMED     // Chuyến đi chính thức đã phê duyệt
}

model Trip {
  id              String           @id @default(uuid())
  ownerId         String
  title           String
  description     String?
  destinationName String
  startDate       DateTime?        // Chuyển thành optional
  endDate         DateTime?        // Chuyển thành optional
  totalBudget     Float            @default(0.0)
  travelStyle     String           @default("solo") // "solo", "family", "friends", "couple"
  isPublic        Boolean          @default(false)
  status          TripStatus       @default(CONFIRMED)
  cloneSourceId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  owner           User             @relation("UserTrips", fields: [ownerId], references: [id], onDelete: Cascade)
  cloneSource     Trip?            @relation("ClonedTrips", fields: [cloneSourceId], references: [id])
  clonedTrips     Trip[]           @relation("ClonedTrips")
  days            TripDay[]
  posts           Post[]
  recommendations Recommendation[]

  @@index([ownerId])
  @@index([cloneSourceId])
}

model TripDay {
  id         String         @id @default(uuid())
  tripId     String
  dayIndex   Int
  date       DateTime?      // Chuyển thành optional
  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities TripActivity[]

  @@unique([tripId, dayIndex])
}

model TripActivity {
  id            String       @id @default(uuid())
  tripDayId     String
  destinationId String?      // Chuyển thành optional
  title         String?      // Tên hoạt động tự do
  location      String?      // Mô tả vị trí tự do
  description   String?      // Chi tiết hoạt động
  startTime     String?      // HH:MM format (optional)
  endTime       String?      // HH:MM format (optional)
  estimatedCost Float        @default(0.0)
  sequenceOrder Int
  notes         String?
  tripDay       TripDay      @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([tripDayId])
  @@index([destinationId])
}

model Destination {
  id            String         @id @default(uuid())
  name          String
  description   String?
  latitude      Float          // For Leaflet plotting
  longitude     Float          // For Leaflet plotting
  category      String         // "restaurant", "hotel", "attraction"
  averageRating Float          @default(0.0)
  address       String?
  openingHours  String?
  activities    TripActivity[]
  checkIns      CheckIn[]
  recommendations Recommendation[]
  events        Event[]
  travelHistories     TravelHistory[]
  userRecommendations UserRecommendation[]
  posts               Post[]

  // Compound index to speed up spatial bounding box searches
  @@index([latitude, longitude])
}

model Post {
  id         String     @id @default(uuid())
  authorId   String
  content    String
  mediaUrls  String[]
  tripId     String?
  locationId String?
  createdAt  DateTime   @default(now())
  deletedAt  DateTime?
  
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  trip        Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  destination Destination? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  comments    Comment[]
  likes       Like[]
  bookmarks   Bookmark[]

  @@index([authorId])
  @@index([tripId])
  @@index([locationId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Bookmark {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follower {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Conversation {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  participants User[]    @relation("ConversationParticipants")
  messages     Message[]
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  type        String   // "like", "comment", "friend_request", "invitation"
  content     String
  isRead      Boolean  @default(false)
  targetId    String?
  createdAt   DateTime @default(now())
  
  recipient   User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
}

model CheckIn {
  id            String      @id @default(uuid())
  userId        String
  destinationId String
  note          String?
  createdAt     DateTime    @default(now())
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([destinationId])
}

model Location {
  id        String   @id @default(uuid())
  userId    String   @unique
  latitude  Float
  longitude Float
  updatedAt DateTime @updatedAt
  
  user      User     @relation("UserLiveLocation", fields: [userId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id                   String      @id @default(uuid())
  tripId               String
  destinationId        String
  score                Float       // Recommendation confidence/relevance score [0..1]
  recommendationReason String?
  
  trip                 Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  destination          Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model AIHistory {
  id           String   @id @default(uuid())
  userId       String
  promptText   String
  responseJson String
  type         String   // "itinerary", "cost_prediction", "route_optimization"
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
// JOURNEY — A travel story / blog-style trip journal
// ═══════════════════════════════════════════════════════════
model Journey {
  id            String         @id @default(uuid())
  userId        String
  title         String
  description   String?
  coverImageUrl String?
  isPublic      Boolean        @default(true)
  status        String         @default("draft") // "draft", "active", "completed"
  startDate     DateTime?
  endDate       DateTime?
  totalDistance  Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  routes        Route[]

  @@index([userId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════
// ROUTE — A specific route/path within a Journey
// ═══════════════════════════════════════════════════════════
model Route {
  id            String       @id @default(uuid())
  journeyId     String
  name          String
  description   String?
  transportMode String       @default("walking") // "walking", "driving", "cycling", "transit"
  distanceKm    Float        @default(0)
  durationMin   Int          @default(0)
  color         String       @default("#D4A843") // hex color for map polyline
  createdAt     DateTime     @default(now())

  journey       Journey      @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  points        RoutePoint[]

  @@index([journeyId])
}

// ═══════════════════════════════════════════════════════════
// ROUTE POINT — Individual GPS waypoint on a Route
// ═══════════════════════════════════════════════════════════
model RoutePoint {
  id            String   @id @default(uuid())
  routeId       String
  latitude      Float
  longitude     Float
  altitude      Float?
  sequenceOrder Int
  timestamp     DateTime @default(now())
  note          String?
  photoUrl      String?

  route         Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([latitude, longitude])
}

// ═══════════════════════════════════════════════════════════
// LOCATION HISTORY — Historical GPS breadcrumbs for a user
// ═══════════════════════════════════════════════════════════
model LocationHistory {
  id        String   @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?   // GPS accuracy in meters
  speed     Float?   // m/s
  heading   Float?   // degrees
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([latitude, longitude])
}

// ═══════════════════════════════════════════════════════════
// EVENT — Local events, festivals, meetups at destinations
// ═══════════════════════════════════════════════════════════
model Event {
  id            String      @id @default(uuid())
  title         String
  description   String?
  coverImageUrl String?
  destinationId String?
  latitude      Float
  longitude     Float
  startDate     DateTime
  endDate       DateTime?
  category      String      // "festival", "meetup", "tour", "workshop", "cultural"
  maxAttendees  Int?
  currentCount  Int         @default(0)
  organizerId   String
  isPublic      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  organizer     User         @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees     EventAttendee[]

  @@index([latitude, longitude])
  @@index([startDate])
  @@index([category])
  @@index([organizerId])
}

model EventAttendee {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("going") // "going", "interested", "maybe"
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ═══════════════════════════════════════════════════════════
// TRAVELER MATCH — AI-based traveler compatibility matching
// ═══════════════════════════════════════════════════════════
model TravelerMatch {
  id              String   @id @default(uuid())
  userId          String
  matchedUserId   String
  compatScore     Float    // 0.0 - 1.0 similarity score
  matchReasons    String[] // ["similar_interests", "same_destination", "overlap_dates"]
  status          String   @default("suggested") // "suggested", "accepted", "declined"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("TravelerMatchUser", fields: [userId], references: [id], onDelete: Cascade)
  matchedUser     User     @relation("TravelerMatchTarget", fields: [matchedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, matchedUserId])
  @@index([userId])
  @@index([matchedUserId])
  @@index([compatScore])
}

model ChatConversation {
  id        String        @id @default(uuid())
  userId    String
  title     String?       @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id             String               @id @default(uuid())
  conversationId String
  role           String               // "user", "assistant", "system"
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  conversation   ChatConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  versions       ChatMessageVersion[]
  feedback       AIFeedback?
  toolCalls      ToolCall[]
  aiChatLog      AIChatLog?

  @@index([conversationId])
}

model ChatMessageVersion {
  id        String      @id @default(uuid())
  messageId String
  content   String
  version   Int         // 1, 2, 3, etc.
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model AIMemory {
  id                String   @id @default(uuid())
  userId            String   @unique
  travelPreferences String[] // sở thích du lịch (e.g. "phượt", "nghỉ dưỡng")
  favoriteFoods     String[] // món ăn yêu thích
  budget            String?  // ngân sách (e.g. "thấp", "trung bình", "cao")
  transportation    String[] // phương tiện di chuyển (e.g. "xe máy", "máy bay")
  favoriteLocations String[] // địa điểm yêu thích
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserRecommendation {
  id            String       @id @default(uuid())
  userId        String
  location      String       // địa điểm đề xuất
  destinationId String?      // [BỔ SUNG] Khóa ngoại trỏ đến địa danh hệ thống
  priority      String       // độ ưu tiên (e.g., "high", "medium", "low")
  reason        String?      // lý do gợi ý
  type          String       // loại gợi ý (e.g., "destination", "food", "activity")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([destinationId])
}

model TravelHistory {
  id            String       @id @default(uuid())
  userId        String
  location      String       // địa điểm đã đi
  destinationId String?      // [BỔ SUNG] Khóa ngoại trỏ đến địa danh hệ thống
  time          DateTime     // thời gian
  rating        String?      // đánh giá
  cost          Float        @default(0.0) // chi phí
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([destinationId])
}

model FavoriteFood {
  id          String   @id @default(uuid())
  userId      String
  name        String   // tên món ăn
  region      String?  // khu vực (ví dụ: Miền Bắc, Hà Nội, v.v.)
  description String?  // mô tả
  rating      Float?   // điểm đánh giá (0 - 5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedPlace {
  id        String   @id @default(uuid())
  userId    String
  name      String   // tên địa điểm
  category  String   // loại địa điểm (e.g. restaurant, hotel, attraction)
  latitude  Float    // vĩ độ (để vẽ bản đồ)
  longitude Float    // kinh độ (để vẽ bản đồ)
  address   String?  // địa chỉ
  imageUrl  String?  // hình ảnh đại diện hoặc hình ảnh địa điểm
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIFeedback {
  id        String      @id @default(uuid())
  userId    String
  messageId String      @unique // 1-1 relationship: mỗi tin nhắn AI chỉ có tối đa 1 feedback
  rating    Int         // điểm đánh giá (e.g. 1-5 hoặc 1: thumbs up, -1: thumbs down)
  comment   String?     // ý kiến đóng góp
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([messageId])
}

model ToolCall {
  id        String      @id @default(uuid())
  messageId String
  toolName  String      // tên tool AI đã dùng (e.g. Maps, Weather, v.v.)
  input     String      // thông tin đầu vào gửi tới tool
  output    String?     // kết quả phản hồi từ tool
  status    String      // trạng thái chạy tool (e.g. "success", "failed")
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model SystemCache {
  key       String   // Khóa tìm kiếm cache (ví dụ: "lat_lng:21.02_105.85" hoặc "query:pho-bo")
  type      String   // Phân loại cache (ví dụ: "place", "food", "blog", "hotel")
  value     String   // Dữ liệu JSON được serialize thành String
  expiresAt DateTime // Thời gian hết hạn đệm
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([key, type]) // Khóa chính composite để cho phép cùng key nhưng khác phân loại
  @@index([type])    // Index để tìm nhanh theo nhóm phân loại
}

model KnowledgeContent {
  id        String              @id @default(uuid())
  title     String
  body      String              // nội dung văn bản tri thức gốc (1 content)
  category  String              // loại tri thức (e.g. culture, festival, food, history, destination)
  questions KnowledgeQuestion[]
  answers   KnowledgeAnswer[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([category])
}

model KnowledgeQuestion {
  id              String                       @id @default(uuid())
  contentId       String
  questionText    String                       // nội dung câu hỏi mẫu (nhiều question)
  embeddingOpenAI Unsupported("vector(1536)")? // Lưu trữ vector embedding OpenAI
  embeddingLocal  Unsupported("vector(128)")?  // Lưu trữ vector embedding Local
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  content         KnowledgeContent             @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model KnowledgeAnswer {
  id         String           @id @default(uuid())
  contentId  String
  answerText String           // nội dung đáp án mẫu (nhiều đáp án)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  content    KnowledgeContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model SafetyWarning {
  id          String    @id @default(uuid())
  type        String    // "FLOOD", "LANDSLIDE", "CLOSED_ROAD", "STORM"
  description String
  latitude    Float
  longitude   Float
  radiusKm    Float     @default(1.0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([latitude, longitude])
}

// =========================================================================
// HỆ THỐNG QUẢN TRỊ AI & KIỂM TOÁN CHATBOT CHUYÊN SÂU
// =========================================================================

// 1. Quản lý Đăng ký và Trạng thái Mô hình (Model Registry)
model ModelRegistry {
  id             String             @id @default(uuid())
  name           String             @unique // Ví dụ: "gpt-4o", "claude-3-5-sonnet"
  provider       String             // Ví dụ: "openai", "anthropic"
  type           String             // "llm" | "embedding" | "reranker" | "nli"
  version        String             // Phiên bản cụ thể: "2024-05-13"
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  chatLogs       AIChatLog[]        @relation("UsedModel")
}

// 2. Quản lý Phiên bản Tri thức (Knowledge Versioning)
model KnowledgeVersion {
  id             String             @id @default(uuid())
  versionNumber  Int                @unique
  commitMessage  String?
  createdAt      DateTime           @default(now())
  freshnessLogs  KnowledgeFreshness[]
}

// 3. Quản lý Phiên bản Prompt (Prompt Versioning)
model PromptVersion {
  id             String             @id @default(uuid())
  templateName   String             // Ví dụ: "rag_qa_system"
  versionHash    String             @unique // Git-like hash
  templateText   String             @db.Text
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  chatLogs       AIChatLog[]        @relation("UsedPrompt")
}

// 4. Nhật ký chất lượng phản hồi AI chi tiết (AIChatLog)
model AIChatLog {
  id                 String             @id @default(uuid())
  messageId          String             @unique
  query              String             @db.Text
  llmPrompt          String             @db.Text
  llmResponse        String             @db.Text
  
  // RAG & Scores
  similarityScore    Float
  confidenceScore    Int
  reliabilityLevel   String
  groundednessScore  Int
  claimVerScore      Int
  retrievedContext   String             @db.Text // JSON string
  
  // ROI & Performance
  promptTokens       Int
  completionTokens   Int
  totalTokens        Int
  apiCostUsd         Float
  latencyMs          Int
  ttftMs             Int
  
  // Security
  guardrailsBlocked  Boolean            @default(false)
  securityThreatType String?            // "PROMPT_INJECTION" | "JAILBREAK" | "PII_LEAK"
  unsupportedClaims  Int                @default(0)
  
  // Relations
  modelId            String
  promptId           String
  model              ModelRegistry      @relation("UsedModel", fields: [modelId], references: [id])
  prompt             PromptVersion      @relation("UsedPrompt", fields: [promptId], references: [id])
  message            ChatMessage        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userFeedbacks      UserFeedback[]
  evalHistories      EvaluationHistory[]
  guardrailEvents    GuardrailEvent[]
  
  createdAt          DateTime           @default(now())
  
  @@index([confidenceScore])
  @@index([reliabilityLevel])
}

// 5. Quản lý Phản hồi Người dùng (User Feedback Learning)
model UserFeedback {
  id             String             @id @default(uuid())
  chatLogId      String
  rating         Int                // 1 (Upvote) hoặc -1 (Downvote)
  comment        String?            @db.Text
  correctedText  String?            @db.Text // Câu trả lời sửa lại từ người dùng
  isProcessed    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  chatLog        AIChatLog          @relation(fields: [chatLogId], references: [id], onDelete: Cascade)

  @@index([chatLogId])
}

// 6. Siêu dữ liệu Caching Ngữ nghĩa (Semantic Cache Metadata)
model CacheMetadata {
  id             String             @id @default(uuid())
  cacheKey       String             @unique // Hash của embedding câu hỏi
  queryText      String             @db.Text
  responseJson   String             @db.Text
  hitCount       Int                @default(1)
  expiresAt      DateTime
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

// 7. Lịch sử Đánh giá Chất lượng Tự động (Evaluation History)
model EvaluationHistory {
  id             String             @id @default(uuid())
  chatLogId      String
  metricName     String             // "groundedness" | "faithfulness" | "answer_relevance"
  score          Float
  evaluatorModel String             // Tên model chạy eval
  reasoning      String?            @db.Text
  createdAt      DateTime           @default(now())
  chatLog        AIChatLog          @relation(fields: [chatLogId], references: [id], onDelete: Cascade)

  @@index([chatLogId])
}

// 8. Nhật ký Sự kiện Vi phạm An ninh (Guardrail Event)
model GuardrailEvent {
  id             String             @id @default(uuid())
  chatLogId      String?
  ruleViolated   String             // "PROMPT_INJECTION" | "TOXICITY" | "PII" | "JUNK"
  severity       String             // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  payloadBlocked String             @db.Text
  actionTaken    String             // "BLOCKED" | "REDACTED" | "WARNING"
  createdAt      DateTime           @default(now())
  chatLog        AIChatLog?         @relation(fields: [chatLogId], references: [id], onDelete: SetNull)

  @@index([chatLogId])
}

// 9. Giám sát Độ tươi mới Tri thức RAG (Knowledge Freshness & Drift)
model KnowledgeFreshness {
  id             String             @id @default(uuid())
  contentId      String
  knowledgeCat   String             // "food" | "culture" | "festival" | "history" | "destination"
  lastCheckedAt  DateTime           @default(now())
  driftDetected  Boolean            @default(false)
  sourceHash     String?
  versionId      Int
  version        KnowledgeVersion   @relation(fields: [versionId], references: [versionNumber])

  @@index([contentId])
}

// 10. Vết Kiểm toán Hệ thống AI (AI Audit Trail)
model AuditTrail {
  id             String             @id @default(uuid())
  actionType     String             // "PROMPT_UPDATE" | "KNOWLEDGE_SEED" | "MODEL_SWITCH" | "CLEAR_CACHE"
  actorName      String             // Tên người dùng / System
  description    String             @db.Text
  ipAddress      String?
  createdAt      DateTime           @default(now())
}
